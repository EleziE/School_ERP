<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Form-->
        <record id="administration_form_view" model="ir.ui.view">
            <field name="name">Administration Form</field>
            <field name="model">administration.administration</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <field name="user_id"></field>
                        <field name="name"></field>
                        <field name="email"></field>
                    </sheet>
                </form>
            </field>
        </record>
        <!--Tree-->
        <record id="administration_tree_view" model="ir.ui.view">
            <field name="name">Administration Tree</field>
            <field name="model">administration.administration</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="user_id"></field>
                    <field name="name"></field>
                    <field name="email"></field>
                </tree>
            </field>
        </record>
        <!--Action-->
        <record id="administration_action" model="ir.actions.act_window">
            <field name="name">Administration Action</field>
            <field name="res_model">administration.administration</field>
            <field name="view_mode">tree,form</field>
            <field name="view_ids"
                   eval="[(5, 0, 0),
                          (0, 0, {'view_mode': 'tree', 'view_id': ref('administration_tree_view')}),
                          (0, 0, {'view_mode': 'form', 'view_id': ref('administration_form_view')})]"/>
        </record>
    </data>
</odoo>