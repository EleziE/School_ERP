<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <!--Form-->
        <record id="view_hospital_doctors_form" model="ir.ui.view">
            <field name="model">hospital.doctors</field>
            <field name="name">hospital.doctors.form</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="surname"/>
                                <field name="specialisation"/>
                            </group>
                            <group>
                                <field name='gender'/>
                                <field name="dob"/>
                                <field name="age"/>
                            </group>
                            <group>
                                <field name="patient_id" options="{'no_create':True}"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <!--TREE-->
        <record id="view_hospital_doctors_tree" model="ir.ui.view">
            <field name="model">hospital.doctors</field>
            <field name="name">hospital.doctors.tree</field>
            <field name="arch" type="xml">
                <tree sample="1" duplicate="false" export_xlsx='false' delete="false">
                    <field name="name"/>
                    <field name="surname"
                           optional="show"/>
                    <field name="specialisation"
                           optional="show"/>
                    <field name='gender'
                           optional="show"/>
                    <field name="age"
                           optional="show"/>
                </tree>
            </field>
        </record>
        <!--Search-->
        <record id="view_hospital_doctors_search" model="ir.ui.view">
            <field name="name">view.hospital.doctors.search</field>
            <field name="model">hospital.doctors</field>
            <field name="arch" type="xml">
                <search>
                    <filter name="gender_female" string="Female" domain="[('gender','=','female')]"/>
                    <separator/>
                    <filter name="gender_male" string="Male" domain="[('gender','=','male')]"/>
                    <group expand="0" string="Group By">
                        <filter name="surname" string="Surname" context="{'group_by':'surname'}"/>
                        <separator/>
                        <filter name="gender"   string="Gender" context="{'group_by':'gender'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!--ACTION-->
        <record id="action_hospital_doctor" model="ir.actions.act_window">
            <field name="name">Doctor</field>
            <field name="res_model">hospital.doctors</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first doctor !
                </p>
            </field>
        </record>
    </data>
</odoo>