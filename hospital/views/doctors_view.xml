<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <!--Form-->
        <record id="view_hospital_doctors_form" model="ir.ui.view">
            <field name="model">hospital.doctors</field>
            <field name="name">hospital.doctors.form</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="surname"/>
                                <field name="specialisation"/>
                            </group>
                            <group>
                                <field name='gender'/>
                                <field name="dob"/>
                                <field name="age"/>
                            </group>
                            <group>
                                <field name="patient_id" options="{'no_create':True}"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <!--TREE-->
        <record id="view_hospital_doctors_tree" model="ir.ui.view">
            <field name="model">hospital.doctors</field>
            <field name="name">hospital.doctors.tree</field>
            <field name="arch" type="xml">
                <tree sample="1">
                    <field name="name"/>
                    <field name="surname"
                           optional="show"/>
                    <field name="specialisation"
                           optional="show"/>
                    <field name='gender'
                           optional="show"/>
                    <field name="age"
                           optional="show"/>
                </tree>
            </field>
        </record>
        <!--ACTION-->
        <record id="action_hospital_doctor" model="ir.actions.act_window">
            <field name="name">Doctor</field>
            <field name="res_model">hospital.doctors</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first doctor !
                </p>
            </field>
        </record>
    </data>
</odoo>