<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <!--Form of Patient Only-->
        <record id="view_hospital_patient_only_form" model="ir.ui.view">
            <field name="model">hospital.patient</field>
            <field name="name">hospital.patient.form</field>
            <field name="inherit_id" ref="view_hospital_patient_form"/>
            <field name="arch" type="xml">
                <field name="name" position="attributes">
                    <attribute name="readonly">1</attribute>
                </field>
                <xpath expr="//field[@name='name']" position="replace">
                    <field name="Emri" string="Emri"/>
                </xpath>
            </field>
        </record>

        <!--TREE of Patient Only-->
        <record id="view_hospital_patient_only_tree" model="ir.ui.view">
            <field name="model">hospital.patient</field>
            <field name="name">hospital.patient.tree</field>
            <field name="inherit_id" ref="view_hospital_patient_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='surname']" position="replace">
                    <field name="middle_name" string="Middle name"/>
                </xpath>
            </field>
        </record>
        <!--Action    -->
        <record id="action_hospital_patient_only" model="ir.actions.act_window">
            <field name="name">Patient</field>
            <field name="res_model">hospital.patient</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first patient !
                </p>
            </field>
        </record>
    </data>
</odoo>