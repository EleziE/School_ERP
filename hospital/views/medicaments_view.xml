<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!--Form-->
        <record id="view_hospital_medicaments_form" model="ir.ui.view">
            <field name="model">hospital.medicaments</field>
            <field name="name">hospital.medicaments.form</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="number"/>
                            </group>
                            <group>
                                <field name="manufacturer"/>
                                <field name="expiration_date"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <!--TREE-->
        <record id="view_hospital_medicaments_tree" model="ir.ui.view">
            <field name="model">hospital.medicaments</field>
            <field name="name">hospital.medicaments.tree</field>
            <field name="arch" type="xml">
                <tree sample="1">
                    <field name="name"/>
                    <field name="manufacturer"/>
                    <field name="expiration_date"/>
                    <field name='number'/>
                </tree>
            </field>
        </record>
        <!--ACTION-->
        <record id="action_hospital_medicaments" model="ir.actions.act_window">
            <field name="name">Medicament</field>
            <field name="res_model">hospital.medicaments</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Enter your first medicament !
                </p>
            </field>
        </record>
    </data>
</odoo>