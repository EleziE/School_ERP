<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>
        <!--Form-->
        <record id="view_hospital_appointment_form" model="ir.ui.view">
            <field name="model">hospital.appointments</field>
            <field name="name">hospital.appointment.form</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="state" widget="statusbar" nolabel="True" options="{'clickable':'False'}"
                               statusbar_visible="personal_info,date_time,recheck,submit"/>
                        <button name="action_go_to_date_time" string="Next" type="object" class="btn-primary" invisible="state != 'personal_info'"/>
                        <button name="action_go_to_recheck" string="Next: Recheck" type="object" class="btn-primary" invisible="state != 'date_time'"/>
                        <button name="action_go_back" string="Back" type="object" class="btn-secondary" invisible="state == 'personal_info'"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h3>
                                <field name="priority" widget="priority"/>
                            </h3>
                        </div>
                        <group>
                            <group>
                                <field name="patient_id"/>
                                <field name="doctor_id"/>
                            </group>
                            <group>
                                <field name="appointment_date"/>
                                <field name="appointment_time"/>
                                <button name="action_test" string="Object button" type="object"
                                        class="btn-secondary text-nowrap"/>
                            </group>
                        </group>
                    </sheet>
                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>
        <!--Tree-->
        <record id="view_hospital_appointments_tree" model="ir.ui.view">
            <field name="model">hospital.appointments</field>
            <field name="name">hospital.appointments.tree</field>
            <field name="arch" type="xml">
                <tree sample="1">
                    <field name="priority" widget="priority" readonly="True"/>
                    <field name="patient_id" readonly="True"/>
                    <field name="doctor_id" readonly="True"/>
                    <field name="appointment_date" widget="date" readonly="True"/>
                    <field name="appointment_time" readonly="True"/>
                </tree>
            </field>
        </record>
        <!--Search-->
        <record id="view_hospital_appointments_search" model="ir.ui.view">
            <field name="name">view.hospital.appointments.search</field>
            <field name="model">hospital.appointments</field>
            <field name="arch" type="xml">
                <search>
                    <group expand="0" string="Group By">
                        <filter name="sate" string="State" context="{'group_by':'state'}"/>
                        <filter name="priority" string="Priority" context="{'group_by':'priority'}"/>
                    </group>
                </search>
            </field>
        </record>
        <!--Action-->
        <record id="action_hospital_appointment" model="ir.actions.act_window">
            <field name="name">Appointment</field>
            <field name="res_model">hospital.appointments</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first appointment !
                </p>
            </field>
        </record>
    </data>
</odoo>