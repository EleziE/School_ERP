<?xml version="1.0" encoding="UTF-8" ?>

<odoo>
    <data>

        <!--Form Doctors Only-->
        <record id="view_hospital_doctors_only_form" model="ir.ui.view">
            <field name="model">hospital.doctors</field>
            <field name="name">hospital.doctors.only.form</field>
            <field name="inherit_id" ref="view_hospital_doctors_form"/>
            <field name="arch" type="xml">

            </field>
        </record>


        <!--TREE Doctors Only-->
        <record id="view_hospital_doctors_only_tree" model="ir.ui.view">
            <field name="model">hospital.doctors</field>
            <field name="name">hospital.doctors.only.tree</field>
            <field name="inherit_id" ref="view_hospital_doctors_tree"/>
            <field name="arch" type="xml">

            </field>
        </record>
        <!--ACTION Doctors Only-->
        <record id="action_hospital_doctor_only" model="ir.actions.act_window">
            <field name="name">hospital.doctors.only.action</field>
            <field name="res_model">hospital.doctors</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first doctor !
                </p>
            </field>
        </record>
    </data>
</odoo>