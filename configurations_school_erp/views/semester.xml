<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Tree-->
    <record id="semester_tree_view" model="ir.ui.view">
        <field name="model">semester.semester</field>
        <field name="arch" type="xml">
            <tree>
                <field name="year"/>
                <field name="name"/>
                <field name="code"/>
                <field name="order"/>
            </tree>
        </field>
    </record>
    <!--Form-->
    <record id="semester_form_view" model="ir.ui.view">
        <field name="model">semester.semester</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="year"/>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="order"/>
                </group>
            </form>
        </field>
    </record>
    <!--Action-->
    <record id="action_semester" model="ir.actions.act_window">
        <field name="name">Semester</field>
        <field name="res_model">semester.semester</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>