<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Tree-->
        <record id="class_tree_view" model="ir.ui.view">
            <field name="model">class.rooms</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="name"/>
                </tree>
            </field>
        </record>
        <!--Form-->
        <record id="class_form_view" model="ir.ui.view">
            <field name="model">class.rooms</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="name"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <!--Action-->
        <record id="action_class_room" model="ir.actions.act_window">
            <field name="name">Classrooms</field>
            <field name="res_model">class.rooms</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>