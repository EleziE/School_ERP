    <!--
    Discuss  menuitem to be visible only for the selected groups
    Name has been changed
    -->
    <record id="mail.menu_root_discuss" model="ir.ui.menu">
        <field name="name">Messenger</field>
        <field name="groups_id" eval="[(6, 0, [
        ref('base_school_erp.group_school_admin'),
        ref('base_school_erp.group_school_administration'),
        ref('base_school_erp.group_school_teacher')])]"/>
        <field name="web_icon">base_school_erp,static/description/discuss.png</field>
    </record>
    <!--Contacts  menuitem to be visible only for the selected groups-->
    <record id="contacts.menu_contacts" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('base_school_erp.group_school_admin')])]"/>
    </record>
    <!--added field in base-->
    <record id="base_view_users_tree_inherited" model="ir.ui.view">
        <field name="name">base.view.users.tree.inherited</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='login']" position="after">
                <field name="member_type" readonly="1"/>
            </xpath>
        </field>
    </record>

    <!--Added search fields and filters-->
    <record id="base_view_users_search_inherited" model="ir.ui.view">
        <field name="name">base.view.users.search.inherited</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_search"/>
        <field name="arch" type="xml">
            <xpath expr="//search" position="inside">
                <field name="member_type"/>
                <separator/>
                <filter name="teacher" string="Teacher" domain="[('member_type','=','teacher')]"/>
                <filter name="student" string="Student" domain="[('member_type','=','student')]"/>
                <group expand="0" string="Group By" colspan="4" col="4">
                    <filter string="Member" name="member" domain="[]" context="{'group_by':'member_type'}"/>
                </group>
            </xpath>
        </field>
    </record>
    <!--
           Just to make the first view to be tree not kanban that is by default
           Nothing else, for the Apps
           -->
    <record id="base.open_module_tree" model="ir.actions.act_window" forcecreate="False">
        <field name="view_mode">tree,kanban,form</field>
    </record>
</odoo>