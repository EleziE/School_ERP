<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="student_view_users_simple_form_inherited" model="ir.ui.view">
            <field name="name">student.view.users.simple.form.inherited</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_simple_form"/>
            <field name="arch" type="xml">
                <xpath expr="//sheet" position="replace">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="surname"/>
                                <field name="gender"/>
                            </group>
                            <group>
                                <field name="phone" placeholder="+355XX XXX XXXX"/>
                                <field name="login"/>
                                <field name="blood_type"/>
                                <field name="dob"/>
                            </group>
                        </group>
                    </sheet>
                </xpath>
            </field>
        </record>
    </data>
</odoo>