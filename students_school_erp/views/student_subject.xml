<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Form-->
        <record id="student_subject_form_view" model="ir.ui.view">
            <field name="name">students.subject.form.subject</field>
            <field name="model">student.subjects</field>
            <field name="arch" type="xml">
                <form string="Student Academic Details">
                    <sheet>
                        <group>
                            <group string="Academic Information">
                                <field name="faculty" readonly="1"/>
                                <field name="year" readonly="1"/>
                                <field name="semester" readonly="1"/>
                            </group>
                            <group string="Student Reference">
                                <field name="student_id" readonly="1"/>
                                <field name="student_name" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <!--Search-->
        <record id="student_subject_search" model="ir.ui.view">
            <field name="name">student.subject.search</field>
            <field name="model">student.subjects</field>
            <field name="arch" type="xml">
                <search>
                    <field name="student_name"/>
                </search>
            </field>
        </record>
        <!--Tree-->
        <record id="student_subject_tree_view" model="ir.ui.view">
            <field name="name">students.subject.tree.view</field>
            <field name="model">students.students</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="sequence" optional="hide"/>
                    <field name="user_id" string="Name"/>
                    <field name="surname" string="Surname" optional="show"/>
                    <field name="dob" string="Birthday" optional="hide"/>
                    <field name="email"/>
                    <field name="state" widget="badge" decoration-success="state == 'active'"
                           decoration-warning="state in ('suspended','inactive')"
                           decoration-primary="state == 'graduated'"
                           decoration-danger="state == 'rejected'"
                           optional="show"/>
                </tree>
            </field>
            <field name="groups_id"
                   eval="[(4,ref('base_school_erp.group_school_admin','base_school_erp.group_school_administration'))]"/>
        </record>
        <!--Action-->
        <record id="action_student_subject" model="ir.actions.act_window">
            <field name="name">My Academic Profile</field>
            <field name="res_model">students.students</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'default_member_type': 'student'}</field>
            <field name="view_ids"
                   eval="[(5, 0, 0),
                   (0, 0, {'view_mode': 'tree', 'view_id': ref('student_subject_tree_view')}),
                   (0, 0, {'view_mode': 'form', 'view_id': ref('student_subject_form_view')}),]"/>
        </record>
        <!--Only the groups that are added are allowed to see the icon of this module-->
        <record id="students" model="ir.ui.menu">
            <field name="groups_id"
                   eval="[(6,0,[ref('base_school_erp.group_school_admin','base_school_erp.group_school_administration')])]"/>
        </record>
    </data>
</odoo>