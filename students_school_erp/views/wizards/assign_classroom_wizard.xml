<odoo>
    <!-- The popup form -->
    <record id="assign_classroom_wizard_view" model="ir.ui.view">
        <field name="name">assign.classroom.wizard.form</field>
        <field name="model">assign.classroom.wizard</field>
        <field name="arch" type="xml">
            <form string="Assign Students to Classroom">
                <group>
                    <field name="classroom_id"/>
                    <field name="student_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button name="action_assign"
                            string="Confirm"
                            type="object"
                            class="btn-primary"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>


    <record id="action_assign_classroom_wizard" model="ir.actions.act_window">
        <field name="name">Assign Classroom</field>
        <field name="res_model">assign.classroom.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>