<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Form-->
        <record id="students_form_view" model="ir.ui.view">
            <field name="name">students.form.view</field>
            <field name="model">students.students</field>
            <field name="arch" type="xml">
                <form class="student_form_view">
                    <header>
                        <field name="state" widget="statusbar"
                               statusbar_visible="new,active,inactive,suspended,graduated,rejected"
                               options="{'clickable': False}"/>
                        <button name="action_active" type="object" string="Activate"
                                class="btn-primary"
                                invisible="state not in ('inactive', 'suspended','new')"
                                groups="base_school_erp.group_school_admin,base_school_erp.group_school_administration"/>
                        <button name="action_inactive" type="object" string="Deactivate"
                                class="btn-outline-warning"
                                invisible="state != 'active'"
                                groups="base_school_erp.group_school_admin"/>
                        <button name="action_open_suspend_wizard" type="object" string="Suspend"
                                class="btn-outline-danger"
                                invisible="state not in ('active', 'inactive')"
                                groups="base_school_erp.group_school_admin,base_school_erp.group_school_administration"/>
                        <button name="action_graduated" type="object" string="Graduate"
                                class="btn-outline-success"
                                invisible="state not in ('active', 'inactive', 'suspended')"
                                groups="base_school_erp.group_school_admin,base_school_erp.group_school_administration"/>
                        <button name="action_graduated_reverse" type="object" string="Reactivate"
                                class="btn-danger"
                                invisible="state != 'graduated'"
                                groups="base_school_erp.group_school_admin,base_school_erp.group_school_administration"
                        confirm="A graduated student is becoming active again ! Are you sure !?"/>
                        <button name="action_graduate_student_info"
                                type="object"
                                string="Print Report"
                                class="btn-primary"
                                invisible="state != 'graduated'"/>

                    </header>
                    <sheet>
                        <div class="oe_title d-flex align-items-center gap-3 p-2">
                            <field name="image_128"
                                   widget="image"
                                   class="oe_avatar"
                                   options="{'size': [100, 100]}"/>
                            <div class="d-flex flex-column">
                                <h2 class="m-0 text-muted">
                                    <field name="sequence" readonly="1"/>
                                </h2>
                                <h1 class="m-0 d-flex align-items-end gap-4">

                                    <div class="d-flex flex-column">
                                        <label for="name" class="text-muted small mb-0">Name</label>
                                        <field name="name" class="oe_inline"/>
                                    </div>

                                    <div class="d-flex flex-column">
                                        <label for="surname" class="text-muted small mb-0">Surname</label>
                                        <field name="surname" class="oe_inline"/>
                                    </div>

                                </h1></div>
                        </div>
                        <group col="2">
                            <group string="👤 Personal Information">
                                <field name="user_id" invisible="1"/>
                                <field name="name" required="1"/>
                                <field name="surname"/>
                                <field name="gender"/>
                                <field name="dob"/>
                            </group>
                            <group string="🧾 Optional Personal Information">
                                <field name="father_name"/>
                                <field name="mother_name"/>
                                <field name="blood_type"/>
                            </group>
                        </group>
                        <group col="2">
                            <group string="🎓 Academic Information">
                                <field name="member_type" readonly="1"/>
                                <field name="faculty"/>
                                <field name="year"/>
                                <field name="enrollment_date"/>
                                <field name="graduation_date"
                                       invisible="not user_id or state != 'graduated'"/>
                            </group>
                            <group string="📧 Contact Information">
                                <field name="email" required="1"/>
                                <field name="external_email"/>
                            </group>
                        </group>
                        <group string="⚙ Status Details">
                            <field name="state" readonly="1"/>
                            <field name="suspend_reason"
                                   readonly="1"
                                   invisible="state != 'suspended'"/>
                        </group>
                        <notebook invisible="state in ['new','graduated','suspended']">
                            <page string="Finance" name="finance"/>
                            <page string="Teacher" name="teacher"/>
                            <page string="Subjects" name="subject">
                                <field name="subject_id"/>
                            </page>
                        </notebook>
                        <div class="alert alert-warning mt-3">
                            <i class="fa fa-exclamation-triangle me-2"/>
                            If information is incorrect, please contact administration.
                            <br/><br/>
                            <i class="fa fa-envelope me-2"/> admin@admin.com
                            <br/>
                            <i class="fa fa-phone me-2"/> +355 XXX XXXX
                        </div>
                    </sheet>
                    <div class="oe_chatter"
                         groups="base_school_erp.group_school_admin">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>
        <!--Tree-->
        <record id="students_tree_view" model="ir.ui.view">
            <field name="name">students.tree.view</field>
            <field name="model">students.students</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="sequence" optional="hide"/>
                    <field name="user_id" string="Name"/>
                    <field name="surname" string="Surname" optional="show"/>
                    <field name="dob" string="Birthday" optional="hide"/>
                    <field name="email"/>
                    <field name="state" widget="badge" decoration-success="state == 'active'"
                           decoration-warning="state in ('suspended','inactive')"
                           decoration-primary="state == 'graduated'"
                           decoration-danger="state == 'rejected'"
                           optional="show"/>
                </tree>
            </field>
            <field name="groups_id"
                   eval="[(4,ref('base_school_erp.group_school_admin','base_school_erp.group_school_administration'))]"/>
        </record>
        <!--Search-->
        <record id="student_view_search" model="ir.ui.view">
            <field name="name">student.view.search</field>
            <field name="model">students.students</field>
            <field name="arch" type="xml">
                <search>
                    <field name="sequence"/>
                    <field name="name"/>
                    <field name="surname"/>
                    <filter name="state" string="Active Student" domain="[('state','=','active')]"/>
                    <separator/>
                    <filter name="state" string="Graduated " domain="[('state','=','graduated')]"/>
                    <group expand="0" string="Group By">
                        <filter name="gender" string="Gender" context="{'group_by':'gender'}"/>
                        <filter name="state" string="Status" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>
        <!--Action-->
        <record id="action_students" model="ir.actions.act_window">
            <field name="name">Students</field>
            <field name="res_model">students.students</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'default_member_type': 'student', 'force_member_type': 'student'}</field>
            <field name="view_ids"
                   eval="[(5, 0, 0),
                   (0, 0, {'view_mode': 'tree', 'view_id': ref('students_tree_view')}),
                   (0, 0, {'view_mode': 'form', 'view_id': ref('students_form_view')}),]"/>
        </record>
        <!--Only the groups that are added are allowed to see the icon of this module-->
        <record id="students" model="ir.ui.menu">
            <field name="groups_id"
                   eval="[(6,0,[ref('base_school_erp.group_school_admin','base_school_erp.group_school_administration')])]"/>
        </record>
    </data>
</odoo>