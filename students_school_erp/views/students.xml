<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Tree-->
    <record id="students_tree_view" model="ir.ui.view">
        <field name="name">studnets.tree.view</field>
        <field name="model">students.students</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="surname"/>
                <field name="gender"/>
                <field name="dob"/>
            </tree>
        </field>
    </record>


    <!--Form-->
    <record id="students_form_view" model="ir.ui.view">
        <field name="name">students.form.view</field>
        <field name="model">students.students</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="surname"/>
                            <field name="gender"/>
                        </group>
                        <group>
                            <field name="dob"/>
                            <field name="classroom_id"/>
                            <field name="subject_ids" widget="many2many_tags"/>
                            <field name="email"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Finance" name="finance">
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


    <!--Action-->
    <record id="action_students" model="ir.actions.act_window">
        <field name="name">Students</field>
        <field name="res_model">students.students</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--menuitem-->
    <menuitem name="students"
              id="Students"
              action="action_students"/>
</odoo>