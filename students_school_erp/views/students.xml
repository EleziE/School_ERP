<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Form-->
        <record id="students_form_view" model="ir.ui.view">
            <field name="name">students.form.view</field>
            <field name="model">students.students</field>
            <field name="arch" type="xml">
                <form class="student_form_view">
                    <sheet class="p-0">
                        <div class="p-3 pb-0">
                            <div class="o_status_box" style="display: flex; justify-content: flex-end;">
                                <field name="state" widget="statusbar"
                                       statusbar_visible="new,active,inactive,suspended,graduated,rejected"
                                       options="{'clickable': False}"/>
                            </div>
                        </div>
                        <div class="p-3">
                            <div class="d-flex align-items-center gap-3 o_student_header">
                                <field name="image_128"
                                       widget="image"
                                       class="oe_avatar"
                                       options="{'size': [90, 90]}"/>
                                <div class="flex-grow-1">
                                    <div class="text-muted small">Student ID</div>
                                    <div style="font-size:1.2rem; font-weight:600;">
                                        <field name="sequence" readonly="1"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="p-3">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="o_card_box">
                                        <h5>👤 Personal Information</h5>
                                        <field name="user_id" invisible="1"/>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Name</strong>
                                            <field name="name" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Surname</strong>
                                            <field name="surname" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Gender</strong>
                                            <field name="gender" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Date of Birth</strong>
                                            <field name="dob" nolabel="1"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="o_card_box">
                                        <h5>🧾 Optional Information</h5>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Father Name</strong>
                                            <field name="father_name" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Mother Name</strong>
                                            <field name="mother_name" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Blood Type</strong>
                                            <field name="blood_type" nolabel="1"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row g-3 mt-1">
                                <div class="col-md-6">
                                    <div class="o_card_box">
                                        <h5>🎓 Academic Information</h5>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Member Type</strong>
                                            <field name="member_type" readonly="1" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Faculty</strong>
                                            <field name="faculty" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Year</strong>
                                            <field name="year" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Enrollment Date</strong>
                                            <field name="enrollment_date" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Graduation Date</strong>
                                            <field name="graduation_date" nolabel="1"
                                                   invisible="not user_id or state != 'graduated'"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="o_card_box">
                                        <h5>📧 Contact Information</h5>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Email</strong>
                                            <field name="email" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">External Email</strong>
                                            <field name="external_email" nolabel="1"/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="mt-3">
                                <div class="o_status_box">
                                    <h5>⚙ Status Details</h5>
                                    <div class="mb-2">
                                        <strong class="d-block mb-1">Status</strong>
                                        <field name="state" readonly="1" nolabel="1"/>
                                    </div>
                                    <div class="mb-2">
                                        <strong class="d-block mb-1">Suspend Reason</strong>
                                        <field name="suspend_reason" readonly="1" nolabel="1"
                                               invisible="state != 'suspended'"/>
                                    </div>
                                </div>
                            </div>
                            <notebook class="mt-3"
                                      invisible="state in ['new','graduated','suspended']">
                                <page string="Finance" name="finance"/>
                                <page string="Teacher" name="teacher"/>
                                <page string="Subjects" name="subject">
                                    <field name="subject_id"/>
                                </page>
                            </notebook>
                        </div>
                        <div class="p-3">
                            <div class="o_footer_box">
                                <i class="fa fa-info-circle text-primary me-2"/>
                                If information is incorrect, contact administration.
                                <br/>
                                <i class="fa fa-envelope me-2"/> admin@admin.com
                                <br/>
                                <i class="fa fa-phone me-2"/> +355 XXX XXXX
                            </div>
                        </div>
                        <div class="oe_chatter"
                             groups="base_school_erp.group_school_admin">
                            <field name="message_follower_ids"/>
                            <field name="activity_ids"/>
                            <field name="message_ids"/>
                        </div>
                    </sheet>
                </form>
            </field>
        </record>
        <!--Tree-->
        <record id="students_tree_view" model="ir.ui.view">
            <field name="name">students.tree.view</field>
            <field name="model">students.students</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="sequence" optional="hide"/>
                    <field name="user_id" string="Name"/>
                    <field name="surname" string="Surname" optional="show"/>
                    <field name="dob" string="Birthday" optional="hide"/>
                    <field name="email"/>
                    <field name="state" widget="badge" decoration-success="state == 'active'"
                           decoration-warning="state in ('suspended','inactive')"
                           decoration-primary="state == 'graduated'"
                           decoration-danger="state == 'rejected'"
                           optional="show"/>
                </tree>
            </field>
            <field name="groups_id"
                   eval="[(4,ref('base_school_erp.group_school_admin','base_school_erp.group_school_administration'))]"/>
        </record>
        <!--Kanban-->
        <record id="students_kanban_view" model="ir.ui.view">
            <field name="name">students.kanban.view</field>
            <field name="model">students.students</field>
            <field name="arch" type="xml">
                <kanban class="student_kanban_view" quick_create="false">

                    <field name="id"/>
                    <field name="name"/>
                    <field name="surname"/>
                    <field name="sequence"/>
                    <field name="email"/>
                    <field name="faculty"/>
                    <field name="year"/>
                    <field name="state"/>
                    <field name="image_128"/>
                    <field name="enrollment_date"/>

                    <templates>
                        <t t-name="kanban-box">

                            <!-- ONLY CHANGE: added oe_kanban_global_click -->
                            <div class="oe_kanban_global_click"
                                 style="border-radius:12px; border:1px solid #e8ecf0; box-shadow:0 2px 8px rgba(0,0,0,0.06); overflow:hidden; background:white; margin:4px;">

                                <!-- Header -->
                                <div style="background:linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%); padding:14px 16px; display:flex; align-items:center; gap:12px;">
                                    <img t-att-src="kanban_image('students.students', 'image_128', record.id.raw_value)"
                                         style="width:48px; height:48px; border-radius:50%; border:2px solid rgba(255,255,255,0.3); object-fit:cover;"
                                         alt="Avatar"/>
                                    <div>
                                        <div style="color:white; font-weight:700; font-size:1rem; line-height:1.2;">
                                            <t t-esc="record.name.value"/>
                                            <t t-esc="' '"/>
                                            <t t-esc="record.surname.value"/>
                                        </div>
                                        <div style="color:rgba(255,255,255,0.55); font-size:0.72rem; letter-spacing:0.8px; text-transform:uppercase; margin-top:2px;">
                                            <t t-esc="record.sequence.value"/>
                                        </div>
                                    </div>
                                </div>

                                <!-- Body -->
                                <div style="padding:12px 16px; background:#f8f9fc;">
                                    <div style="display:flex; justify-content:space-between; font-size:0.82rem; color:#555; margin-bottom:6px;">
                                        <span style="color:#0f3460; font-weight:600;">Faculty</span>
                                        <span><t t-esc="record.faculty.value or 'N/A'"/></span>
                                    </div>
                                    <div style="display:flex; justify-content:space-between; font-size:0.82rem; color:#555; margin-bottom:6px;">
                                        <span style="color:#0f3460; font-weight:600;">Year</span>
                                        <span><t t-esc="record.year.value or 'N/A'"/></span>
                                    </div>
                                    <div style="display:flex; justify-content:space-between; font-size:0.82rem; color:#555; margin-bottom:6px;">
                                        <span style="color:#0f3460; font-weight:600;">Email</span>
                                        <span><t t-esc="record.email.value or 'N/A'"/></span>
                                    </div>
                                    <div style="display:flex; justify-content:space-between; font-size:0.82rem; color:#555;">
                                        <span style="color:#0f3460; font-weight:600;">Enrolled</span>
                                        <span><t t-esc="record.enrollment_date.value or 'N/A'"/></span>
                                    </div>
                                </div>

                                <!-- Footer -->
                                <div style="padding:8px 16px; background:white; border-top:1px solid #e8ecf0; display:flex; justify-content:space-between; align-items:center;">
                                    <field name="state" widget="badge"
                                           decoration-success="state == 'active'"
                                           decoration-warning="state in ('suspended','inactive')"
                                           decoration-primary="state == 'graduated'"
                                           decoration-danger="state == 'rejected'"/>
                                </div>

                            </div>

                        </t>
                    </templates>

                </kanban>
            </field>
        </record>
        <!--Search-->
        <record id="student_view_search" model="ir.ui.view">
            <field name="name">student.view.search</field>
            <field name="model">students.students</field>
            <field name="arch" type="xml">
                <search>
                    <field name="sequence"/>
                    <field name="name"/>
                    <field name="surname"/>
                    <filter name="state" string="Active Student" domain="[('state','=','active')]"/>
                    <separator/>
                    <filter name="state" string="Graduated " domain="[('state','=','graduated')]"/>
                    <group expand="0" string="Group By">
                        <filter name="gender" string="Gender" context="{'group_by':'gender'}"/>
                        <filter name="state" string="Status" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>
        <!--Action-->
        <record id="action_students" model="ir.actions.act_window">
            <field name="name">Students</field>
            <field name="res_model">students.students</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="context">{'default_member_type': 'student', 'force_member_type': 'student'}</field>
            <field name="view_ids"
                   eval="[(5, 0, 0),
                   (0, 0, {'view_mode': 'kanban', 'view_id': ref('students_kanban_view')}),
                   (0, 0, {'view_mode': 'tree', 'view_id': ref('students_tree_view')}),
                   (0, 0, {'view_mode': 'form', 'view_id': ref('students_form_view')}),]"/>
        </record>
        <!--Only the groups that are added are allowed to see the icon of this module-->
        <record id="students" model="ir.ui.menu">
            <field name="groups_id"
                   eval="[(6,0,[ref('base_school_erp.group_school_admin','base_school_erp.group_school_administration')])]"/>
        </record>
    </data>
</odoo>