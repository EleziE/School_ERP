<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Form-->
        <record id="students_form_view" model="ir.ui.view">
            <field name="name">students.form.view</field>
            <field name="model">students.students</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="state" widget="statusbar"
                               statusbar_visible="new,active,inactive,suspended,graduated,rejected"
                               options="{'clickable': False}"/>
                        <button name="action_active" type="object" string="Activate"
                                invisible="state not in ('inactive', 'suspended','new')"
                                groups="base_school_erp.group_school_admin"/>
                        <button name="action_inactive" type="object" string="Deactivate"
                                invisible="state != 'active'"
                                groups="base_school_erp.group_school_admin"/>
                        <button name="action_open_suspend_wizard" type="object" string="Suspend" class="btn-danger"
                                invisible="state not in ('active', 'inactive')"
                                groups="base_school_erp.group_school_admin"/>
                        <button name="action_graduated" type="object" string="Graduated"
                                invisible="state not in ('active', 'inactive', 'suspended')"
                                groups="base_school_erp.group_school_admin"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h3>
                                <field name="sequence" readonly="1"/>
                            </h3>
                        </div>
                        <group>
                            <group>
                                <field name="user_id" string="Name" domain=" [('member_type','=','student')]"/>
                                <field name="surname" invisible=" not user_id"/>
                                <field name="gender" placeholder="Select..." invisible=" not user_id"/>
                                <field name="enrollment_date" invisible=" not user_id"/>
                            </group>
                            <group>
                                <field name="dob" invisible=" not user_id"/>
                                <field name="classroom_id" invisible="state == 'graduated'"/>
                                <field name="subject_id" widget="many2many_tags" invisible="state == 'graduated'"/>
                                <field name="email" invisible=" not user_id"/>
                                <field name="blood_type" invisible=" not user_id"/>
                                <field name="enrollment_date" invisible=" not user_id"/>
                                <field name="suspend_reason" readonly="1" invisible="state != 'suspended'"/>
                                <field name="state" readonly="1" invisible="not user_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Finance" name="finance" invisible=" not user_id">
                            </page>
                            <page string="Teacher" name="teacher" invisible=" not user_id">
                            </page>
                            <page string="Subjects" name="subject" invisible=" not user_id">
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <!--Tree-->
        <record id="students_tree_view" model="ir.ui.view">
            <field name="name">students.tree.view</field>
            <field name="model">students.students</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="sequence"/>
                    <field name="user_id" string="Name"/>
                    <field name="surname" string="Surname"/>
                    <field name="email"/>
                    <field name="state" widget="badge" decoration-success="state == 'active'"
                           decoration-warning="state in ('suspended','inactive')"
                           decoration-primary="state == 'graduated'"
                           decoration-danger="state == 'rejected'"/>
                </tree>
            </field>
            <field name="groups_id"
                   eval="[(4,ref('base_school_erp.group_school_admin'))]"/>
        </record>
        <!--Search-->
        <record id="student_view_search" model="ir.ui.view">
            <field name="name">student.view.search</field>
            <field name="model">students.students</field>
            <field name="arch" type="xml">
                <search>
                    <field name="sequence"/>
                    <field name="name"/>
                    <field name="surname"/>
                    <filter name="state" string="Active Student" domain="[('state','=','active')]"/>
                    <separator/>
                    <filter name="state" string="Graduated " domain="[('state','=','graduated')]"/>
                    <group expand="0" string="Group By">
                        <filter name="gender" string="Gender" context="{'group_by':'gender'}"/>
                        <filter name="state" string="Status" context="{'group_by':'state'}"/>
                    </group>
                </search>
            </field>
        </record>
        <!--Action-->
        <record id="action_students" model="ir.actions.act_window">
            <field name="name">Students</field>
            <field name="res_model">students.students</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'default_member_type':'student','force_member_type':'student'}</field>
        </record>
    </data>
</odoo>