<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Teacher Task Form-->
        <record id="my_tasks_teacher_form" model="ir.ui.view">
            <field name="name">My Task (Teacher Form)</field>
            <field name="model">task</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="check_user_finish_date" invisible="True"/>
                            <field name="starting_date"/>
                            <field name="planned_finish_date"/>
                            <field name="finish_date" invisible="not check_user_finish_date"/>
                            <field name="status" widget="badge"
                                   decoration-success="status in ('completed','completed_early')"
                                   decoration-warning="status == 'in_progress'"
                                   decoration-danger="status == 'completed_delayed'"/>

                            <field name="description"
                                   placeholder="Information about the task..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <!--Teacher Task Kanban-->
        <record id="my_tasks_teacher_kanban" model="ir.ui.view">
            <field name="name">My Task (Teacher Kanban)</field>
            <field name="model">task</field>
            <field name="arch" type="xml">
                <kanban default_group_by="status">
                    <field name="starting_date"/>
                    <field name="planned_finish_date"/>
                    <field name="finish_date"/>
                    <field name="status"/>
                    <templates>
                        <t t-name="kanban-box">
                            <t t-if="record.status.raw_value != 'in_progress' and
                             record.status.raw_value != 'new'">
                                <div class="oe_kanban_global_click o_kanban_record">

                                    <!-- Status Badge -->
                                    <div class="o_kanban_record_top mb-2">
                                        <div class="o_kanban_record_headings">
                                            <strong class="o_kanban_record_title">
                                            </strong>
                                        </div>
                                        <div>
                                            <span t-attf-class="badge rounded-pill
                                        #{record.status.raw_value == 'completed' ? 'text-bg-success' :
                                          record.status.raw_value == 'completed_early' ? 'text-bg-success' :
                                          record.status.raw_value == 'completed_delayed' ? 'text-bg-danger' :
                                          'text-bg-secondary'}">
                                                <field name="status"/>
                                            </span>
                                        </div>
                                    </div>

                                    <!-- Card Body -->
                                    <div class="o_kanban_record_body">
                                        <div class="d-flex justify-content-between">
                                            <span class="text-muted">
                                                <i class="fa fa-user me-1"/>
                                            </span>
                                        </div>
                                        <div class="mt-1">
                                            <i class="fa fa-calendar me-1 text-muted"/>
                                            <span class="text-muted">Start: </span>
                                            <field name="starting_date"/>
                                        </div>
                                        <div class="mt-1">
                                            <i class="fa fa-calendar-check-o me-1 text-muted"/>
                                            <span class="text-muted">Planned: </span>
                                            <field name="planned_finish_date"/>
                                        </div>
                                        <t t-if="record.finish_date.raw_value">
                                            <div class="mt-1">
                                                <i class="fa fa-flag-checkered me-1 text-muted"/>
                                                <span class="text-muted">Finished: </span>
                                                <field name="finish_date"/>
                                            </div>
                                        </t>
                                    </div>

                                </div>
                            </t>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        <!--Teacher Task Tree-->
        <record id="my_tasks_teacher_tree" model="ir.ui.view">
            <field name="name">My Task (Teacher Tree)</field>
            <field name="model">task</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="starting_date"/>
                    <field name="planned_finish_date"/>
                    <field name="finish_date"/>
                    <field name="status" widget="badge"
                           decoration-success="status in ('completed','completed_early')"
                           decoration-warning="status == 'in_progress'"
                           decoration-danger="status == 'completed_delayed'"/>

                </tree>
            </field>
        </record>
        <!--Action Teacher-->
        <record id="action_my_task_teacher" model="ir.actions.act_window">
            <field name="name">Task</field>
            <field name="res_model">task</field>
            <field name="view_mode">tree,kanban,form</field>
            <field name="view_ids"
                   eval="[(5, 0, 0),
                          (0, 0, {'view_mode': 'tree', 'view_id': ref('my_tasks_teacher_tree')}),
                          (0, 0, {'view_mode': 'kanban', 'view_id': ref('my_tasks_teacher_kanban')}),
                          (0, 0, {'view_mode': 'form', 'view_id': ref('my_tasks_teacher_form')}),]"/>
        </record>
    </data>
</odoo>