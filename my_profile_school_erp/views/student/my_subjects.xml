<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Form -->
        <record id="my_profile_student_subject_form" model="ir.ui.view">
            <field name="name">my.profile.student.subject.form</field>
            <field name="model">student.subjects</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <field name="faculty"/>
                        <field name="year"/>
                        <field name="semester"/>
                    </group>

                </form>
            </field>
        </record>
        <record id="my_profile_student_subject_tree" model="ir.ui.view">
            <field name="name">my.profile.student.subject.tree</field>
            <field name="model">student.subjects</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="subject_name"/>
                    <field name="passed_subject_ids" optional="hide"/>
                    <field name="upcoming_subject_ids" optional="hide"/>
                    <field name="semester" optional="hide"/>
                    <field name="year" optional="hide"/>
                    <field name="faculty" optional="hide"/>
                </tree>
            </field>
        </record>
        <!--Action -->
        <record id="action_profile_student_subject" model="ir.actions.act_window">
            <field name="name">Students Subject</field>
            <field name="res_model">student.subjects</field>
            <field name="domain">[('student_id.user_id','=',uid)]</field>
            <field name="view_mode">tree,form</field>
            <field name="groups_id" eval="[(4,ref('configurations_school_erp.group_school_student'))]"/>
        </record>
    </data>
</odoo>