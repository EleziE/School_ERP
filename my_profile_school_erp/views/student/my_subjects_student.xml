<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Form-->
        <record id="my_profile_subjects_form" model="ir.ui.view">
            <field name="name">my.subjects.form</field>
            <field name="model">my.subject.student</field>
            <field name="arch" type="xml">
                <form create="False" delete="False" duplicate="False" edit="False">
                    <sheet>
                        <group>
                            <field name="faculty_name"/>
                            <field name="year"/>
                            <field name="semester"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <!--Action-->
        <record id="action_my_subject_student" model="ir.actions.act_window">
            <field name="name">Student Subject</field>
            <field name="res_model">my.subject.student</field>
            <field name="view_mode">form</field>
            <field name="views"
                   eval="[(ref('my_profile_subjects_form')),'form']"/>
            <field name="groups_id" eval="[(4,ref('base_school_erp.group_school_student'))]"/>
        </record>
    </data>
</odoo>