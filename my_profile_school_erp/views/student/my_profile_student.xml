<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Form -->
        <record id="my_profile_student_form" model="ir.ui.view">
            <field name="name">my.profile.student</field>
            <field name="model">my.profile.student</field>
            <field name="arch" type="xml">
                <form edit="False" create="False" duplicate="False">
                    <sheet>
                        <header>
                            <button name="action_print_report"
                                    string="Print Info"
                                    icon="fa-print"
                                    type="object"
                                    class="btn-secondary"
                                    invisible="state in ('suspended','graduated','new','rejected')"/>
                        </header>
                        <group>
                            <group name="Required Information" string="Required Information">
                                <field name="member_type" invisible="True"/>
                                <field name="user_id" invisible="True"/>
                                <field name="sequence"/>
                                <field name="name"/>
                                <field name="surname"/>
                                <field name="state"/>
                                <field name="faculty"/>
                                <field name="year"/>
                            </group>
                            <group name="Extra Information" string="Extra Information">
                                <field name="gender"/>
                                <field name="dob"/>
                                <field name="email"/>
                                <field name="enrollment_date"/>
                                <field name="external_email"/>
                                <field name="blood_type"/>
                                <field name="suspend_reason" invisible="state != 'suspended'"/>
                            </group>
                        </group>
                        <div class="alert alert-warning" role="alert">
                            <i class="fa fa-exclamation-triangle"/>
                            If the information is incorrect, please inform the school administration.
                            <br/>
                            <br/>
                            <i class="fa fa-envelope "/> admin@admin.com
                            <br/>
                            <i class="fa fa-phone"/> +355 XXX XXXX
                        </div>
                    </sheet>
                    <div class="oe_chatter"
                         groups="base_school_erp.group_school_admin">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>
        <!--Action -->
        <record id="action_my_profile_student" model="ir.actions.act_window">
            <field name="name">Student Profile</field>
            <field name="res_model">my.profile.student</field>
            <field name="view_mode">form</field>
            <field name="view_ids"
                   eval="[(5, 0, 0),
                          (0, 0, {'view_mode': 'form', 'view_id': ref('my_profile_student_form')})]"/>
            <field name="groups_id" eval="[(4,ref('base_school_erp.group_school_student'))]"/>
        </record>
    </data>
</odoo>