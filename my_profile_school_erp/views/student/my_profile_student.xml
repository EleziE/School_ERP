<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Form -->
        <record id="my_profile_student_form" model="ir.ui.view">
            <field name="name">my.profile.student</field>
            <field name="model">my.profile.student</field>
            <field name="arch" type="xml">
                <form edit="False" create="False" duplicate="False" class="student_status_badge">
                    <header>
                        <button name="action_print_report"
                                string="Print Info"
                                icon="fa-print"
                                type="object"
                                class="btn-primary"
                                invisible="state in ('suspended','graduated','new','rejected')"/>
                    </header>
                    <sheet>
                        <div class="oe_title d-flex align-items-center gap-3">
                            <field name="image_128"
                                   widget="image"
                                   class="oe_avatar"
                                   options="{'size': [90, 90]}"/>
                            <div class="d-flex flex-column flex-grow-1">
                                <h1 class="m-0 d-flex gap-2 align-items-center">
                                    <field name="name"/>
                                    <field name="surname"/>
                                </h1>
                                <h2 class="text-muted m-0">
                                    <field name="sequence"/>
                                </h2>
                            </div>
                            <div class="ms-auto">
                                <field name="state" widget="badge"
                                       class="fs-5 px-3 py-2"
                                       decoration-success="state == 'active'"
                                       decoration-warning="state == 'new'"
                                       decoration-danger="state == 'suspended'"/>
                            </div>
                        </div>
                        <group col="2">
                            <group string="🎓 Academic Information">
                                <field name="member_type" invisible="True"/>
                                <field name="user_id" invisible="True"/>
                                <field name="faculty"/>
                                <field name="year"/>
                                <field name="enrollment_date"/>
                            </group>
                            <group string="👤 Personal Information">
                                <field name="gender"/>
                                <field name="dob"/>
                                <field name="blood_type"/>
                            </group>
                        </group>
                        <group string="📧 Contact Information" col="2">
                            <field name="email"/>
                            <field name="external_email"/>
                        </group>
                        <group string="⚠ Suspension Details"
                               invisible="state != 'suspended'">
                            <field name="suspend_reason"/>
                        </group>
                        <div class="alert alert-warning mt-3" role="alert">
                            <i class="fa fa-exclamation-triangle me-2"/>
                            <strong>Notice:</strong> If the information is incorrect, please inform the school
                            administration.
                            <br/><br/>
                            <i class="fa fa-envelope me-2"/> admin@admin.com
                            <br/>
                            <i class="fa fa-phone me-2"/> +355 XXX XXXX
                        </div>
                    </sheet>
                    <div class="oe_chatter"
                         groups="base_school_erp.group_school_admin">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>
        <!--Action -->
        <record id="action_my_profile_student" model="ir.actions.act_window">
            <field name="name">Student Profile</field>
            <field name="res_model">my.profile.student</field>
            <field name="view_mode">form</field>
            <field name="view_ids"
                   eval="[(5, 0, 0),
                          (0, 0, {'view_mode': 'form', 'view_id': ref('my_profile_student_form')})]"/>
            <field name="groups_id" eval="[(4,ref('base_school_erp.group_school_student'))]"/>
        </record>
    </data>
</odoo>