<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="my_finance_student_form" model="ir.ui.view">
            <field name="model">finance.finance</field>
            <field name="arch" type="xml">
                <form create="False" delete="False" edit="False">
                    <group>
                        <field name="student_id" domain="[('user_id','=',uid)]"/>
                        <field name="created_by"/>
                        <field name="created_by_info"/>
                        <field name="reason"/>
                        <field name="state"/>
                        <field name="amount"/>
                    </group>
                </form>
            </field>
        </record>
        <record id="my_finance_student_tree" model="ir.ui.view">
            <field name="model">finance.finance</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="student_id"/>
                    <field name="created_by"/>
                    <field name="created_by_info"/>
                    <field name="reason"/>
                    <field name="state"/>
                    <field name="amount"/>
                </tree>
            </field>
        </record>

        <record id="action_my_finance_student" model="ir.actions.act_window">
            <field name="name">Finance</field>
            <field name="res_model">finance.finance</field>
            <field name="view_mode">tree,form</field>
            <field name="context">{'default_user_id': uid}</field>
            <field name="view_ids" eval="[(5,0,0),
                                (0,0,{'view_mode': 'tree','view_id':ref('my_finance_student_tree')}),
                                (0,0,{'view_mode': 'form','view_id':ref('my_finance_student_form')}),
                                ]"/>
        </record>
    </data>
</odoo>