<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="my_finance_student_form" model="ir.ui.view">
            <field name="model">my.finance.student</field>
            <field name="arch" type="xml">
                <form create="False" delete="False" edit="False">
                    <group>
                        <field name="user_id" invisible="True"/>
                        <field name="student_id" domain="[('id','!=',uid)]"/>
                        <field name="created_by"/>
                        <field name="created_by_info"/>
                        <field name="reason"/>
                        <field name="state"/>
                        <field name="amount"/>
                    </group>
                </form>
            </field>
        </record>
        <record id="my_finance_student_tree" model="ir.ui.view">
            <field name="model">my.finance.student</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="student_id"/>
                    <field name="created_by"/>
                    <field name="created_by_info"/>
                    <field name="reason"/>
                    <field name="state"/>
                    <field name="amount"/>
                </tree>
            </field>
        </record>

        <record id="action_my_finance_student" model="ir.actions.act_window">
            <field name="name">Finance</field>
            <field name="res_model">my.finance.student</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>