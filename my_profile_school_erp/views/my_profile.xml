<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Form Student Form-->
        <record id="my_profile_student_form" model="ir.ui.view">
            <field name="name">my.profile.student</field>
            <field name="model">my.profile.student</field>
            <field name="arch" type="xml">
                <form edit="False" create="False" duplicate="False">
                    <sheet>
                        <group>
                            <group>
                                <field name="member_type" invisible="True"/>
                                <field name="user_id" readonly="True" domain="[('member_type','=','student')]"/>
                                <field name="name"/>
                                <field name="surname"/>
                                <field name="state"/>
                                <field name="gender" readonly="True"/>
                                <field name="enrollment_date" readonly="True"/>
                            </group>
                            <group>
                                <field name="dob"/>
                                <field name="classroom_id" invisible="state == 'graduated'" readonly="True"/>
                                <field name="subject_id" widget="many2many_tags" invisible="state == 'graduated'"/>
                                <field name="email" readonly="True"/>
                                <field name="blood_type"/>
                                <field name="suspend_reason" readonly="1" invisible="state != 'suspended'"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <!--Form Teacher Form-->
        <record id="my_profile_teacher_form" model="ir.ui.view">
            <field name="name">my.profile.teacher</field>
            <field name="model">my.profile.teacher</field>
            <field name="arch" type="xml">
                <form create="False" delete="False" edit="False">
                    <sheet>
                        <header>
                            <button name="print_subjects" type="object" string="Print Sub"/>
                        </header>
                        <group>
                            <group string="required_group">
                                <field name="sequence" />
                                <field name="user_id"/>
                                <field name="surname"/>
                            </group>
                            <group string="optional_group">
                                <field name="blood_type"/>
                                <field name="dob"/>
                                <field name="phone"/>
                                <field name="education"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>


        <!--Action Student-->
        <record id="action_my_profile_student" model="ir.actions.act_window">
            <field name="name">Student Profile</field>
            <field name="res_model">my.profile.student</field>
            <field name="view_mode">form</field>
            <field name="views"
                   eval="[(ref('my_profile_student_form')),'form']"/>

            <field name="groups_id" eval="[(4,ref('base_school_erp.group_school_student'))]"/>
        </record>
        <!--Action Teacher-->
        <record id="action_my_profile_teacher" model="ir.actions.act_window">
            <field name="name">My Profile</field>
            <field name="res_model">my.profile.teacher</field>
            <field name="view_mode">form</field>
            <field name="context">{'default_user_id': uid}</field>
            <field name="domain">[('user_id', '=', uid)]</field>
            <field name="views"
                   eval="[(ref('my_profile_teacher_form')),'form']"/>
            <field name="groups_id" eval="[(4,ref('base_school_erp.group_school_teacher'))]"/>
        </record>
    </data>
</odoo>