<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Tree-->
    <record id="task_tree_view" model="ir.ui.view">
        <field name="model">task</field>
        <field name="arch" type="xml">
            <tree>
                <field name="created_by" domain="[('member_type','=','administrator')]"/>
                <field name="created_for"/>
                <field name="starting_date"/>
                <field name="planned_finish_date"/>
                <field name="finish_date"/>
                <field name="status" widget="badge"
                       decoration-success="status in ('completed','completed_early')"
                       decoration-warning="status == 'in_progress'"
                       decoration-danger="status == 'completed_delayed'"/>
            </tree>
        </field>
    </record>
    <!--Form-->
    <record id="task_form_view" model="ir.ui.view">
        <field name="model">task</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status" widget="statusbar" options="{'clickable':True}"/>
                    <button name="action_in_progres" string="In Progress" type="object" invisible="status != 'new'"/>
                    <button name="action_completed" string="Completed" type="object"
                            invisible="status != 'in_progress' or created_for != uid"/>
                </header>
                <sheet>
                    <group>
                        <field name="created_by" options="{'no_open': True, 'no_create':True}"/>
                        <field name="created_for" domain="[('id','!=',created_by)]"/>
                        <field name="starting_date"/>
                        <field name="planned_finish_date"/>
                        <field name="finish_date" readonly='"not check_user_finish_date"'/>
                        <field name="description" placeholder="Information about the task..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--Kanban-->
    <record id="task_kanban_view" model="ir.ui.view">
        <field name="name">task.kanban.view</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <kanban default_group_by="status">
                <field name="status"/>
                <field name="created_by"/>
                <field name="created_for"/>
                <field name="starting_date"/>
                <field name="finish_date"/>

                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card">
                            <div class="oe_kanban_card oe_kanban_global_click">
                                <div class="oe_kanban_content">

                                    <strong>
                                        <field name="description"/>
                                    </strong>

                                    <div>
                                        <b>Created By :</b>
                                        <field name="created_by"/>
                                    </div>

                                    <div>
                                        <b>Assigned To :</b>
                                        <field name="created_for"/>
                                    </div>

                                    <div>
                                        <b>Start :</b>
                                        <field name="starting_date"/>
                                    </div>

                                    <div>
                                        <b>Finish :</b>
                                        <field name="finish_date"/>
                                    </div>

                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
    <!--Action-->
    <record id="action_task" model="ir.actions.act_window">
        <field name="name">Task</field>
        <field name="res_model">task</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="view_ids" eval="[(5,0,0),
                                (0,0,{'view_mode': 'tree','view_id':ref('task_tree_view')}),
                                (0,0,{'view_mode': 'form','view_id':ref('task_form_view')}),
                                (0,0,{'view_mode': 'kanban','view_id':ref('task_kanban_view')}),
                                ]"/>
    </record>
</odoo>