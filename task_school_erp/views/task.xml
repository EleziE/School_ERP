<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Tree-->
    <record id="task_tree_view" model="ir.ui.view">
        <field name="model">task</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" optional="hide"/>
                <field name="created_by" domain="[('member_type','=','administrator')]" />
                <field name="created_for"/>
                <field name="starting_date"/>
                <field name="planned_finish_date"/>
                <field name="finish_date"/>
                <field name="status" widget="badge"
                       decoration-success="status in ('completed','completed_early')"
                       decoration-warning="status == 'in_progress'"
                       decoration-danger="status == 'completed_delayed'"/>
            </tree>
        </field>
    </record>
    <!--Form-->
    <record id="task_form_view" model="ir.ui.view">
        <field name="model">task</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="status"
                           widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <field name="sequence"/>
                        <field name="created_by"
                               options="{'no_open': True, 'no_create':True}"/>
                        <field name="check_user_finish_date" invisible="True"/>
                        <field name="created_for"
                               domain="[('id','!=',created_by)]"
                               options="{'no_open': True, 'no_create':True}"
                               readonly="created_by != uid"/>
                        <field name="starting_date"/>
                        <field name="planned_finish_date"/>
                        <field name="finish_date" invisible="not check_user_finish_date"/>
                        <field name="description"
                               placeholder="Information about the task..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <!--Task Search-->
    <record id="task_view_search" model="ir.ui.view">
        <field name="name">task.view.search</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <search>
                <field name="created_for" groups="base_school_erp.group_school_admin"/>
                <field name="created_by"/>
                <field name="sequence" groups="base_school_erp.group_school_admin"/>
                <filter name="status" string="Completed" domain="[('status','=','completed')]"/>
                <filter name="status" string="Delayed" domain="[('status','=','completed_delayed')]"/>
                <filter name="status" string="Early" domain="[('status','=','completed_early')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="status" string="Status" context="{'group_by':'status'}"/>
                </group>
            </search>
        </field>
    </record>
    <!--Action-->
    <record id="action_task" model="ir.actions.act_window">
        <field name="name">Task</field>
        <field name="res_model">task</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5,0,0),
                                (0,0,{'view_mode': 'tree','view_id':ref('task_tree_view')}),
                                (0,0,{'view_mode': 'form','view_id':ref('task_form_view')}),]"/>
    </record>
</odoo>