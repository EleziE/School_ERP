<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Tree-->
    <record id="task_tree_view" model="ir.ui.view">
        <field name="model">task</field>
        <field name="arch" type="xml">
            <tree duplicate="0">
                <field name="sequence" optional="hide"/>
                <field name="task_from" options="{'no_open':True}" optional="show"
                       groups="base_school_erp.group_school_admin"/>
                <field name="task_for"/>
                <field name="starting_date"/>
                <field name="planned_finish_date"/>
                <field name="finish_date"/>
                <field name="status" widget="badge"
                       decoration-success="status in ('completed','completed_early')"
                       decoration-warning="status == 'in_progress'"
                       decoration-danger="status == 'completed_delayed'"/>
            </tree>
        </field>
    </record>
    <!--Form-->
    <record id="task_form_view" model="ir.ui.view">
        <field name="model">task</field>
        <field name="arch" type="xml">
            <form edit="[('status','not in',['completed','completed_delayed','completed_early'])]"
                  class="task_form_view">
                <header>
                    <button name="action_create_task"
                            string="✅ Create Task"
                            type="object"
                            class="btn-finish-warm rounded-pill fw-bold"
                    invisible="sequence != 'New'"/>

                    <field name="status" widget="statusbar"
                           statusbar_visible="in_progress,completed"/>
                </header>

                <sheet>
                    <xpath expr="." position="inside">
                        <style>
                            .btn-finish-warm {
                                background-image: linear-gradient(to right, #e0f7fa 50%, #00838f 50%) !important;
                                background-size: 200% 100% !important;
                                background-position: left bottom !important;
                                color: #006064 !important;
                                transition: background-position 1.0s ease, color 0.7s ease !important;
                                border: 1px solid #b2ebf2 !important;
                                padding: 8px 20px !important;
                            }

                            .btn-finish-warm:hover {
                                background-position: right bottom !important;
                                color: white !important;
                            }

                            .o_task_main_card {
                                background: #ffffff;
                                border: 1px solid #e9ecef;
                                border-radius: 12px;
                                padding: 20px;
                            }
                        </style>
                    </xpath>

                    <div class="oe_title mb-4">
                        <h1 class="d-flex align-items-center">
                            <field name="sequence" class="text-primary me-2"/>
                        </h1>
                    </div>

                    <div class="o_task_main_card shadow-sm">
                        <group>
                            <group name="assignment_details" string="👥 Assignment">
                                <field name="task_from"
                                       readonly="1"/>
                                <field name="task_for" />
                                <field name="user_id" invisible="1"/>
                            </group>

                            <group name="date_details" string="📅 Timeline">
                                <field name="starting_date"/>
                                <field name="planned_finish_date"/>
                                <field name="finish_date"
                                       invisible="not finish_date"
                                       readonly="1"
                                       force_save="1"/>
                                <field name="check_user_finish_date" invisible="1"/>
                                <field name="check_user_planned_finish_date" invisible="1"/>
                            </group>
                        </group>

                        <separator string="📝 Task Instructions" class="mt-4 fw-bold text-success"/>
                        <field name="description"
                               placeholder="Describe the work to be done..."
                               class="oe_inline w-100 p-3 bg-light border-0 rounded"/>
                    </div>
                </sheet>

                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>
    <!--Task Search-->
    <record id="task_view_search" model="ir.ui.view">
        <field name="name">task.view.search</field>
        <field name="model">task</field>
        <field name="arch" type="xml">
            <search>
                <field name="task_for"/>
                <field name="task_from"/>
                <filter name="status" string="Completed" domain="[('status','=','completed')]"/>
                <filter name="status" string="Delayed" domain="[('status','=','completed_delayed')]"/>
                <filter name="status" string="Early" domain="[('status','=','completed_early')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="status" string="Status" context="{'group_by':'status'}"/>
                    <filter name="task_for" string="Task for" context="{'group_by':'task_for'}" groups="base_school_erp.group_school_administration,base_school_erp.group_school_admin"/>
                    <filter name="task_from" string="Task from" context="{'group_by':'task_from'}" groups="base_school_erp.group_school_administration,base_school_erp.group_school_admin"/>
                </group>
            </search>
        </field>
    </record>
    <!--Action-->
    <record id="action_task" model="ir.actions.act_window">
        <field name="name">Task</field>
        <field name="res_model">task</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(6,0,0),
                                (0,0,{'view_mode': 'tree','view_id':ref('task_tree_view')}),
                                (0,0,{'view_mode': 'form','view_id':ref('task_form_view')}),]"/>
    </record>
    <!--Only Admins are allowed to see the icon of Task module-->
    <record id="task" model="ir.ui.menu">
        <field name="name">Tasks</field>
        <field name="groups_id"
               eval="[(6,0,[ref('base_school_erp.group_school_admin','base_school_erp.group_school_administration')])]"/>
    </record>
</odoo>