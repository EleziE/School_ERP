<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="teacher_form_view_inherit" model="ir.ui.view">
        <field name="name">teacher.form.view.inherit</field>
        <field name="model">teacher.teacher</field>
        <field name="inherit_id" ref="teacher_school_erp.teacher_form_view"/>
        <field name="arch" type="xml">

            <xpath expr="//page[@name='tasks']" position="inside">
                <div class="p-3">
                    <h6 class="fw-bold mb-3 text-muted border-bottom pb-2">
                        <i class="fa fa-check-square-o me-2"/>Teacher Tasks
                    </h6>
                    <field name="task_id"
                           nolabel="1">
                        <tree>
                            <field name="sequence" optional="hide"/>
                            <field name="status" widget="badge"
                                   decoration-success="status in ['completed','completed_early']"
                                   decoration-danger="status in ['completed_delayed']"
                                   decoration-info="status == 'in_progress'"
                            optional="hide"/>
                            <field name="description" optional="hide"/>
                            <field name="planned_finish_date" optional="hide"/>
                            <field name="finish_date" optional="hide"/>
                        </tree>
                    </field>
                </div>
            </xpath>

        </field>
    </record>
</odoo>