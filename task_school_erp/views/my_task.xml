<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Tree-->
        <record id="my_task_tree_view" model="ir.ui.view">
            <field name="model">task</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="created_by"/>
                    <field name="created_for"/>
                    <field name="starting_date"/>
                    <field name="finish_date"/>
                    <field name="status" widget="badge"
                           decoration-success="status == 'completed'"
                           decoration-warning="status == 'in_progres'"
                           decoration-danger="status == 'completed_delayed'"/>
                </tree>
            </field>
        </record>
        <!--Form-->
        <record id="my_task_form_view" model="ir.ui.view">
            <field name="model">task</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="status" widget="statusbar"/>
                        <button name="action_in_progres" string="In Progress" type="object"
                                invisible="status != 'new'"/>
                        <button name="action_completed" string="Completed" type="object"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="created_by" readonly="1" options="{'no_open':True}"/>
                            <field name="created_for"/>
                            <field name="starting_date"/>
                            <field name="finish_date"/>
                            <field name="description" placeholder="Information about the task..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <record id="action_my_task" model="ir.actions.act_window">
            <field name="name"> My Task</field>
            <field name="res_model">task</field>
            <field name="view_mode">tree,form,kanban</field>
            <field name="view_ids" eval="[(5, 0, 0),
                    (0, 0, {'view_mode': 'tree', 'view_id': ref('my_task_tree_view')}),
                    (0, 0, {'view_mode': 'form', 'view_id': ref('my_task_form_view')})]"/>
        </record>
    </data>
</odoo>