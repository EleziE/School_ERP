<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id='teacher_form_view_inherit' model="ir.ui.view">
        <field name="model">teacher.teacher</field>
        <field name="inherit_id" ref="teacher_school_erp.teacher_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='Tasks']">
                <field name="task_id">
                    <tree>
                        <field name="description"/>
                        <field name="status"/>
                        <field name="finish_date"/>
                    </tree>
                </field>
            </xpath>
        </field>
    </record>
</odoo>
