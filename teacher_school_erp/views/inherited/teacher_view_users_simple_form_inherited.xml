<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="teacher_view_users_simple_form_inherited" model="ir.ui.view">
            <field name="name">view.users.simple.form.inherited</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="students_school_erp.student_view_users_simple_form_inherited"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="before">
                    <field name="member_type" placeholder="Select..."/>
                </xpath>
                <xpath expr="//field[@name='gender']" position="before">
                    <field name="enrollment_date"/>
                </xpath>
                <xpath expr="//field[@name='dob']" position="after">
                    <field name="education"/>
                </xpath>
                <xpath expr="//field[@name='education']" position="attributes">
                    <attribute name="invisible">member_type != 'teacher'</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
