<?xml version="1.0" encoding="UTF-8" ?>
<!--Form-->
<odoo>
    <data>
        <!--Form-->
        <record id="teacher_form_view" model="ir.ui.view">
            <field name="name">teacher.form.view</field>
            <field name="model">teacher.teacher</field>
            <field name="arch" type="xml">
                <form class="teacher_form_view">
                    <sheet class="p-0">
                        <div class="p-3 pb-0">
                            <div class="o_status_box"
                                 style="display: flex; justify-content: flex-end; min-height: 35px;">
                            </div>
                        </div>

                        <div class="p-3">
                            <div class="d-flex align-items-center gap-3 o_teacher_header">
                                <field name="image_128"
                                       widget="image"
                                       class="oe_avatar"
                                       options="{'size': [90, 90]}"/>
                                <div class="flex-grow-1">
                                    <div class="text-muted small">Teacher ID</div>
                                    <div style="font-size:1.2rem; font-weight:600;">
                                        <field name="sequence" readonly="1"/>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="p-3">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="o_card_box">
                                        <h5>👤 Personal Information</h5>
                                        <field name="user_id" invisible="1"/>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Name</strong>
                                            <field name="name" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Surname</strong>
                                            <field name="surname" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Email</strong>
                                            <field name="email" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Phone</strong>
                                            <field name="phone" nolabel="1"/>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="o_card_box">
                                        <h5>📑 Professional Details</h5>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Education</strong>
                                            <field name="education" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Date of Birth</strong>
                                            <field name="dob" nolabel="1"/>
                                        </div>
                                        <div class="mb-2">
                                            <strong class="d-block mb-1">Blood Type</strong>
                                            <field name="blood_type" nolabel="1"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <notebook class="mt-3">
                                <page string="Subjects" name="subjects">
                                    <field name="subject_id"/>
                                </page>
                                <page string="Classrooms" name="classrooms">
                                    <field name="class_room_id"/>
                                </page>
                                <page string="Tasks" name="tasks">
                                </page>
                            </notebook>
                        </div>

                        <div class="p-3">
                            <div class="o_footer_box">
                                <i class="fa fa-envelope me-2"/> admin@example.com
                                <br/>
                                <i class="fa fa-phone me-2"/> +355 XXX XXXX
                            </div>
                        </div>

                    </sheet>
                    <div class="oe_chatter"
                         groups="base_school_erp.group_school_admin,base_school_erp.group_school_administration">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>
        <!--Kanban-->
        <record id="teacher_kanban_view" model="ir.ui.view">
            <field name="name">teacher.kanban.view</field>
            <field name="model">teacher.teacher</field>
            <field name="arch" type="xml">
                <kanban class="teacher_kanban_view" quick_create="false">
                    <field name="id"/>
                    <field name="name"/>
                    <field name="surname"/>
                    <field name="sequence"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="education"/>
                    <field name="image_128"/>

                    <templates>
                        <t t-name="kanban-box">
                            <div class="oe_kanban_global_click"
                                 style="border-radius:12px; border:1px solid #e8ecf0; box-shadow:0 2px 8px rgba(0,0,0,0.06); overflow:hidden; background:white; margin:4px;">

                                <div style="background:linear-gradient(135deg,#1a1a2e 0%,#16213e 50%,#0f3460 100%); padding:14px 16px; display:flex; align-items:center; gap:12px;">
                                    <img t-att-src="kanban_image('teacher.teacher', 'image_128', record.id.raw_value)"
                                         style="width:48px; height:48px; border-radius:50%; border:2px solid rgba(255,255,255,0.3); object-fit:cover;"
                                         alt="Teacher Avatar"/>
                                    <div>
                                        <div style="color:white; font-weight:700; font-size:1rem; line-height:1.2;">
                                            <t t-esc="record.name.value"/>
                                            <t t-esc="' '"/>
                                            <t t-esc="record.surname.value"/>
                                        </div>
                                        <div style="color:rgba(255,255,255,0.55); font-size:0.72rem; letter-spacing:0.8px; text-transform:uppercase; margin-top:2px;">
                                            <t t-esc="record.sequence.value"/>
                                        </div>
                                    </div>
                                </div>

                                <div style="padding:12px 16px; background:#f8f9fc;">
                                    <div style="display:flex; justify-content:space-between; font-size:0.82rem; color:#555; margin-bottom:6px;">
                                        <span style="color:#0f3460; font-weight:600;">Education</span>
                                        <span class="text-truncate" style="max-width: 150px; text-align: right;">
                                            <t t-esc="record.education.value or 'N/A'"/>
                                        </span>
                                    </div>
                                    <div style="display:flex; justify-content:space-between; font-size:0.82rem; color:#555; margin-bottom:6px;">
                                        <span style="color:#0f3460; font-weight:600;">Email</span>
                                        <span><t t-esc="record.email.value or 'N/A'"/></span>
                                    </div>
                                    <div style="display:flex; justify-content:space-between; font-size:0.82rem; color:#555;">
                                        <span style="color:#0f3460; font-weight:600;">Phone</span>
                                        <span><t t-esc="record.phone.value or 'N/A'"/></span>
                                    </div>
                                </div>

                                <div style="padding:8px 16px; background:white; border-top:1px solid #e8ecf0; display:flex; justify-content:flex-end; align-items:center; min-height: 40px;">
                                    <i class="fa fa-graduation-cap text-muted opacity-50" title="Education"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        <!--Tree-->
        <record id="teacher_tree_view" model="ir.ui.view">
            <field name="name">teacher.tree.view</field>
            <field name="model">teacher.teacher</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="sequence"/>
                    <field name="name"/>
                    <field name="surname"/>
                    <field name="dob"/>
                    <field name="education" widget="badge"
                           decoration-success="education == 'bachelor'"
                           decoration-warning="education == 'master'"
                           decoration-primary="education == 'doctorate'"/>
                </tree>
            </field>
        </record>
        <!--Only the groups that are added are allowed to see the icon of Teacher module-->
        <record id="teacher" model="ir.ui.menu">
            <field name="groups_id"
                   eval="[(6,0,[ref('base_school_erp.group_school_admin','base_school_erp.group_school_administration')])]"/>
        </record>
        <!--Action-->
        <record id="action_teacher" model="ir.actions.act_window">
            <field name="name">Teacher</field>
            <field name="res_model">teacher.teacher</field>
            <field name="view_mode">kanban,tree,form</field>
            <field name="view_ids"
                   eval="[(5, 0, 0),
                   (0, 0, {'view_mode': 'kanban', 'view_id': ref('teacher_kanban_view')}),
                   (0, 0, {'view_mode': 'tree', 'view_id': ref('teacher_tree_view')}),

                   (0, 0, {'view_mode': 'form', 'view_id': ref('teacher_form_view')}),]"/>
        </record>
    </data>
</odoo>