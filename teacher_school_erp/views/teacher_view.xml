<?xml version="1.0" encoding="UTF-8" ?>
<!--Form-->
<odoo>
    <data>
        <record id="teacher_form_view" model="ir.ui.view">
            <field name="name">teacher.form.view</field>
            <field name="model">teacher.teacher</field>
            <field name="arch" type="xml">
                <form class="teacher_form">
                    <style>
                        .teacher_form .o_form_sheet {
                            max-width: 900px;
                        }
                        .teacher-header {
                            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
                            border-radius: 12px;
                            padding: 28px;
                            margin-bottom: 24px;
                            display: flex;
                            align-items: center;
                            gap: 24px;
                            color: white;
                        }
                        .teacher-header .o_field_image img,
                        .teacher-header .o_field_image .o_image_placeholder {
                            width: 90px !important;
                            height: 90px !important;
                            border-radius: 50% !important;
                            border: 3px solid rgba(255, 255, 255, 0.3) !important;
                            object-fit: cover;
                        }

                        .teacher-header-info {
                            flex: 1;
                        }
                        .teacher-header-info .teacher-name {
                            color: white !important;
                            font-size: 1.6rem;
                            font-weight: 700;
                            margin: 0 0 4px 0;
                            display: flex;
                            gap: 8px;
                        }
                        .teacher-header-info .teacher-name .o_field_widget input,
                        .teacher-header-info .teacher-name .o_field_widget span {
                            color: white !important;
                            font-size: 1.6rem !important;
                            font-weight: 700 !important;
                        }
                        .teacher-header-info .field-label {
                            color: rgba(255, 255, 255, 0.5);
                            font-size: 0.7rem;
                            letter-spacing: 1px;
                            text-transform: uppercase;
                            margin-bottom: 2px;
                        }
                        .teacher-header-info .field-row {
                            display: flex;
                            align-items: center;
                            gap: 6px;
                            color: rgba(255, 255, 255, 0.85);
                            font-size: 0.9rem;
                            margin-top: 6px;
                        }
                        .teacher-header-info .field-row .o_field_widget {
                            color: rgba(255, 255, 255, 0.85) !important;
                        }
                        .teacher-header-info .teacher-id {
                            color: rgba(255, 255, 255, 0.5);
                            font-size: 0.78rem;
                            letter-spacing: 1px;
                            text-transform: uppercase;
                            margin-top: 4px;
                        }
                        .info-card {
                            background: #f8f9fc;
                            border: 1px solid #e8ecf0;
                            border-radius: 10px;
                            padding: 20px;
                            margin-bottom: 16px;
                            height: 100%;
                        }
                        .info-card-title {
                            font-size: 0.7rem;
                            font-weight: 700;
                            letter-spacing: 1.5px;
                            text-transform: uppercase;
                            color: #0f3460;
                            margin-bottom: 14px;
                            padding-bottom: 8px;
                            border-bottom: 2px solid #0f3460;
                            display: flex;
                            align-items: center;
                            gap: 8px;
                        }
                        .teacher_form .o_notebook .nav-link {
                            font-weight: 600;
                            letter-spacing: 0.5px;
                        }
                        .teacher_form .o_notebook .nav-link.active {
                            color: #0f3460 !important;
                            border-bottom-color: #0f3460 !important;
                        }

                        .notebook-card {
                            background: #f8f9fc;
                            border: 1px solid #e8ecf0;
                            border-radius: 10px;
                            padding: 16px;
                            margin-bottom: 16px;
                            display: inline-block;
                            width: 100%;
                        }

                        .notebook-card .o_field_one2many .o_list_view,
                        .notebook-card .o_field_many2many .o_list_view {
                            background: transparent !important;
                            border: none !important;
                        }
                    </style>
                    <sheet>
                        <div class="teacher-header">
                            <field name="image_128"
                                   widget="image"
                                   options="{'size': [90, 90]}"/>
                            <div class="teacher-header-info">
                                <div class="field-label">Full Name</div>
                                <div class="teacher-name">
                                    <field name="name" placeholder="Name"/>
                                    <field name="surname" placeholder="Surname"/>
                                </div>
                                <div class="teacher-id">
                                    ID: <field name="sequence"/>
                                </div>
                                <div class="field-row">
                                    <span>✉</span>
                                    <span class="field-label" style="margin:0">Email:</span>
                                    <field name="email" placeholder="email@school.com"/>
                                </div>

                            </div>
                            <field name="user_id"
                                   domain="[('member_type', '=', 'teacher')]"
                                   options="{'no_open':True, 'no_create':True}"
                                   invisible="True"/>
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <div class="info-card">
                                    <div class="info-card-title">👤 Personal Information</div>
                                    <group>
                                        <field name="dob" string="Date of Birth"/>
                                        <field name="blood_type"/>
                                        <field name="phone"/>
                                    </group>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="info-card">
                                    <div class="info-card-title">🎓 Professional Information</div>
                                    <group>
                                        <field name="education"/>
                                        <field name="faculty"/>
                                    </group>
                                </div>
                            </div>
                        </div>
                        <notebook>
                            <page name="subjects" string="📖 Subjects">
                                <div class="notebook-card">
                                    <div class="info-card-title">📖 Subjects</div>
                                    <field name="subject_id"
                                           nolabel="1"
                                           options="{'no_create':True}">
                                        <tree editable="bottom">
                                            <field name="name"/>
                                            <field name="faculty"/>
                                            <field name="year"/>
                                            <field name="credits"/>
                                        </tree>
                                    </field>
                                </div>
                            </page>
                            <page name="classroom" string="🏫 Classroom">
                                <div class="notebook-card">
                                    <div class="info-card-title">🏫 Classroom</div>
                                    <field name="class_room_id"
                                           nolabel="1"
                                           options="{'no_create':True}">
                                        <tree editable="bottom">
                                            <field name="name"/>
                                        </tree>
                                    </field>
                                </div>
                            </page>
                            <page name="Tasks" string="✅ Tasks">
                            </page>
                        </notebook>
                    </sheet>
                    <div class="oe_chatter"
                         groups="base_school_erp.group_school_admin,base_school_erp.group_school_administration">
                        <field name="message_follower_ids"/>
                        <field name="activity_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>
        <!--Tree-->
        <record id="teacher_tree_view" model="ir.ui.view">
            <field name="name">teacher.tree.view</field>
            <field name="model">teacher.teacher</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="sequence"/>
                    <field name="name"/>
                    <field name="surname"/>
                    <field name="dob"/>
                    <field name="education" widget="badge"
                           decoration-success="education == 'bachelor'"
                           decoration-warning="education == 'master'"
                           decoration-primary="education == 'doctorate'"/>
                </tree>
            </field>
        </record>
        <!--Only the groups that are added are allowed to see the icon of Teacher module-->
        <record id="teacher" model="ir.ui.menu">
            <field name="groups_id"
                   eval="[(6,0,[ref('base_school_erp.group_school_admin','base_school_erp.group_school_administration')])]"/>
        </record>
        <!--Action-->
        <record id="action_teacher" model="ir.actions.act_window">
            <field name="name">Teacher</field>
            <field name="res_model">teacher.teacher</field>
            <field name="view_mode">tree,form</field>
            <field name="view_ids"
                   eval="[(5, 0, 0),
                   (0, 0, {'view_mode': 'tree', 'view_id': ref('teacher_tree_view')}),
                   (0, 0, {'view_mode': 'form', 'view_id': ref('teacher_form_view')}),]"/>
        </record>
    </data>
</odoo>