<?xml version="1.0" encoding="UTF-8" ?>
<!--Form-->
<odoo>
    <data>
        <record id="teacher_form_view" model="ir.ui.view">
            <field name="name">teacher.form.view</field>
            <field name="model">teacher.teacher</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <group>
                                <field name="sequence"/>
                                <field name="user_id" domain="[('member_type', '=', 'teacher')]"/>
                                <field name="name" invisible="not user_id"/>
                                <field name="surname" invisible="not user_id"/>
                                <field name="blood_type" invisible="not user_id"/>
                            </group>
                            <group>
                                <field name="dob" invisible="not user_id"/>
                                <field name="phone" invisible="not user_id"/>
                                <field name="education" invisible="not user_id"/>
                            </group>
                        </group>
                        <notebook>
                            <page name="Subjects">
                                <group name="main">
                                    <group name="right">
                                        <field name="class_room_id"></field>
                                    </group>
                                    <group name="left">
                                        <field name="subject_id"/>
                                    </group>
                                </group>
                            </page>
                            <page name="Tasks">
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
        <!--Tree-->
        <record id="teacher_tree_view" model="ir.ui.view">
            <field name="name">teacher.tree.view</field>
            <field name="model">teacher.teacher</field>
            <field name="arch" type="xml">
                <tree>
                    <field name="sequence"/>
                    <field name="name"/>
                    <field name="surname"/>
                    <field name="education"/>
                    <field name="dob"/>
                    <field name="enrollment_date"/>
                </tree>
            </field>
        </record>
        <!--Action-->
        <record id="action_teacher" model="ir.actions.act_window">
            <field name="name">Teacher</field>
            <field name="res_model">teacher.teacher</field>
            <field name="view_mode">tree,form</field>
            <field name="view_ids"
                   eval="[(5, 0, 0),
                   (0, 0, {'view_mode': 'tree', 'view_id': ref('teacher_tree_view')}),
                   (0, 0, {'view_mode': 'form', 'view_id': ref('teacher_form_view')}),]"/>
        </record>
    </data>
</odoo>