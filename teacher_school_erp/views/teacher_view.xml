<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Tree-->
    <record id="teacher_tree_view" model="ir.ui.view">
        <field name="name">teacher.tree.view</field>
        <field name="model">teacher.teacher</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence"/>
                <field name="name"/>
                <field name="surname"/>
                <field name="education"/>
                <field name="dob"/>
                <field name="enrollment_date"/>
            </tree>
        </field>
    </record>
    <!--Form-->
    <record id="teacher_form_view" model="ir.ui.view">
        <field name="name">teacher.form.view</field>
        <field name="model">teacher.teacher</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="sequence"/>
                            <field name="user_id" domain="[('member_type', '=', 'teacher')]"/>
                            <field name="name"/>
                            <field name="surname"/>
                            <field name="blood_type"/>
                        </group>
                        <group>
                            <field name="dob"/>
                            <field name="phone"/>
                            <field name="education"/>
                        </group>
                    </group>
                    <notebook>
                        <page name="Subjects">
                            <group name="main">
                                <group name="right">
                                    <field name="class_room_id"></field>
                                </group>
                                <group name="left">
                                    <field name="subject_id"/>
                                </group>
                            </group>
                        </page>
                        <page name="Tasks">
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!--Action-->
    <record id="action_teacher" model="ir.actions.act_window">
        <field name="name">Teacher</field>
        <field name="res_model">teacher.teacher</field>
        <field name="view_mode">tree,form</field>
    </record>

</odoo>