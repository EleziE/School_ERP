<odoo>
    <data noupdate="1">
        <!--Member ID-->
        <record id="sequence_library_member" model="ir.sequence">
            <field name="name">Library Member Sequence</field>
            <field name="code">library.member</field>
            <field name="prefix">MEM-</field>
            <field name="padding">3</field>
        </record>

        <!--Borrow ID-->
        <record id="sequence_library_borrow" model="ir.sequence">
            <field name="name">Sequence Library Borrow</field>
            <field name="code">library.borrow</field>
            <field name="prefix">BOR-</field>
            <field name="padding">3</field>
        </record>
    </data>
</odoo>