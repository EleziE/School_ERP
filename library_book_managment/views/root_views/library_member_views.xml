<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Form-->
    <record id="library_member_form_view" model="ir.ui.view">
        <field name="name">library.member.form.view</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <field name="state" widget="statusbar"/>
                    <button name="action_state_active" string="Active" type="object" invisible="state != 'expired'"
                            class="btn-primary"/>
                    <button name="action_state_suspended" string="Suspended" type="object" invisible="state != 'active'"
                            class="btn-primary"/>
                    <button name="action_state_expired" string="Expired" type="object" invisible="state != 'suspended'"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <group name="main_group">
                        <group name="group_1">
                            <field name="member_code"/>
                            <field name="partner_id"/>
                        </group>
                        <group name="group_2">
                            <field name="join_date"/>
                            <field name="expiry_date"/>
                        </group>
                        <group name="group_3">
                            <field name="state"/>
                            <field name="borrow_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Borrow ID's">
                            <field name="borrow_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <!--List-->
    <record id="library_member_tree_view" model="ir.ui.view">
        <field name="name">library.member.tree.view</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <tree>
                <field name="partner_id"/>
                <field name="member_code"/>
                <field name="join_date"/>
                <field name="expiry_date"/>
                <field name="state"/>
            </tree>
        </field>
    </record>
    <!--Search-->
    <record id="library_member_search_view" model="ir.ui.view">
        <field name="name">library.member.search.view</field>
        <field name="model">library.member</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <filter name="active" string="Active" domain="[('state','=','active')]"/>
                <filter name="expired" string="Expired" domain="[('state','=','expired')]"/>
                <filter name="suspended" string="Suspended" domain="[('state','=','suspended')]"/>
                <group expand="0" string="Group By">
                    <filter name="state" string="State" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!--Action-->
    <record id="action_library_member" model="ir.actions.act_window">
        <field name="name">Library Members</field>
        <field name="res_model">library.member</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
    </record>

    <menuitem id="menu_library_member"
              parent="root_library"
              name="Members"
              action="action_library_member"
              sequence="2"/>
</odoo>