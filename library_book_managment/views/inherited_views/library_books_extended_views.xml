<odoo>
    <record id="library_books_form_view_inherited" model="ir.ui.view">
        <field name="name">library.books.form.view.inherited</field>
        <field name="model">library.books</field>
        <field name="inherit_id" ref="library_books_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='publisher']" position="after">
                <field name="language"/>
            </xpath>
            <xpath expr="//group[@name='right_side']" position="inside">
                <field name="pages"/>
            </xpath>
        </field>
    </record>

</odoo>