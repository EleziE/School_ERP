<odoo>
    <record id="library_borrow_form_view_inherited" model="ir.ui.view">
        <field name="name">library.borrow.form.view.inherited</field>
        <field name="model">library.borrow</field>
        <field name="inherit_id" ref="library_borrow_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='main_group']" position="after">
                <notebook string="Notes">
                    <page string="Notes">
                        <group>
                            <field name="notes"/>
                        </group>
                    </page>
                </notebook>
            </xpath>
        </field>
    </record>
</odoo>