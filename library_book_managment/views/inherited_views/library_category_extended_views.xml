<odoo>
    <record id="library_category_form_view_inherited" model="ir.ui.view">
        <field name="name">library.category.form.view.inherited</field>
        <field name="model">library.category</field>
        <field name="inherit_id" ref="library_category_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='page_books']" position="replace">
                <page string="Books" name="page_books">
                    <group>
                        <field name="book_count"/>
                    </group>
                    <field name="book_ids"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>