<odoo>
    <record id="library_member_form_view_inherited" model="ir.ui.view">
        <field name="name">library.member.form.view.inherited</field>
        <field name="model">library.member</field>
        <field name="inherit_id" ref="library_member_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="phone"/>
            </xpath>
        </field>
    </record>
</odoo>