<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_print_paid_finances_wizard_form" model="ir.ui.view">
            <field name="name">print.paid.finances.wizard.form</field>
            <field name="model">print.paid.finances.wizard</field>
            <field name="arch" type="xml">
                <form string="Print Report">
                    <group>
                        <field name="student_id" options="{'no_open':True}"/>
                        <field name="state" />
                    </group>
                    <footer>
                        <button name="action_print_report" string="Download PDF" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_print_paid_finances" model="ir.actions.act_window">
            <field name="name">Print Paid Finances</field>
            <field name="res_model">print.paid.finances.wizard</field>
            <field name="view_mode">form</field>
            <field name="context">{'default_student_id': active_id}</field>
            <field name="target">new</field>
        </record>
    </data>

</odoo>