<odoo>
    <record id="view_finance_report_wizard" model="ir.ui.view">
        <field name="name">finance.report.wizard.form</field>
        <field name="model">finance.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Finance Report Wizard">
                <group>
                    <field name="student_id" string="Student"/>
                    <field name="date_start" string="Start Date"/>
                    <field name="date_end" string="End Date"/>
                </group>

                <footer>
                    <!-- Generate PDF button -->
                    <button name="action_generate_report"
                            type="object"
                            string="Generate PDF"
                            class="btn-primary"/>
                    <button string="Cancel" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action to open the wizard -->
    <record id="finance_report_wizard" model="ir.actions.act_window">
        <field name="name">Finance Report</field>
        <field name="res_model">finance.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field> <!-- Opens as popup -->
    </record>
</odoo>