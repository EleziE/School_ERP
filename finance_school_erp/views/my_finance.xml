<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <!--Form-->
        <record id="my_finance_form_view" model="ir.ui.view">
            <field name="name">finance.form.view</field>
            <field name="model">finance.finance</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="pay_finance" string="Pay" type="object" invisible="state == 'paid'"/>
                        <button name="unpaid_finance" string="Unpaid" type="object" invisible="state == 'unpaid'"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,paid,unpaid"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="student_id"/>
                            <field name="create_date"/>
                            <field name="amount"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
        <!--Action-->
        <record id="action_my_finance" model="ir.actions.act_window">
            <field name="name">My Finance</field>
            <field name="res_model">finance.finance</field>
            <field name="view_mode">form</field>
            <field name="context">{'default_user_id':uid}</field>
        </record>
    </data>
</odoo>