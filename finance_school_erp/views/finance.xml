<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Tree-->
    <record id="finance_tree_view" model="ir.ui.view">
        <field name="name">finance.tree.view</field>
        <field name="model">finance.finance</field>
        <field name="arch" type="xml">
            <tree>
                <field name="student_id"/>
                <field name="create_date"/>
                <field name="paid_date"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'paid'"
                       decoration-danger="state == 'unpaid'"/>
                <field name="amount"/>
            </tree>
        </field>
    </record>
    <!--Form-->
    <record id="finance_form_view" model="ir.ui.view">
        <field name="name">finance.form.view</field>
        <field name="model">finance.finance</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="pay_finance"
                            string="Pay"
                            type="object"
                            invisible="state == 'paid'"
                            groups="base_school_erp.group_school_admin"/>
                    <button name="unpaid_finance"
                            string="Unpaid"
                            type="object"
                            invisible="state == 'unpaid'"
                            groups="base_school_erp.group_school_admin"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,paid,unpaid"/>
                </header>
                <sheet>
                    <group>
                        <field name="student_id" options="{'no_open':True, 'no_create':True}"
                               domain="[('member_type','=','student')]"/>
                        <field name="create_date"/>
                        <field name="amount"/>
                        <field name="paid_date"/>
                        <field name="state" widget="badge"
                               decoration-success="state == 'paid'"
                               decoration-warning="state == 'draft'"
                               decoration-danger="state == 'unpaid'"/>
                        <field name="reason" placeholder="Write the reason for suspension..."
                               options="{'rows': 5,'no_open':True,'no_create':True,'no_delete':True}"/>
                    </group>
                </sheet>
                <footer>
                    <button name="%(finance_report_wizard)d"
                            type="action"
                            string="Finance Report"/>
                </footer>
            </form>
        </field>
    </record>
    <!--Action-->
    <record id="action_finance" model="ir.actions.act_window">
        <field name="name">Finance</field>
        <field name="res_model">finance.finance</field>
        <field name="view_mode">tree,form</field>
        <field name="view_ids" eval="[(5,0,0),
                                (0,0,{'view_mode': 'tree','view_id':ref('finance_tree_view')}),
                                (0,0,{'view_mode': 'form','view_id':ref('finance_form_view')}),
                                ]"/>
    </record>
    <!--Only the groups that are added are allowed to see the icon of Finance module-->
    <record id="finance" model="ir.ui.menu">
        <field name="groups_id" eval="[(6,0,[ref('base_school_erp.group_school_admin')])]"/>
    </record>

</odoo>