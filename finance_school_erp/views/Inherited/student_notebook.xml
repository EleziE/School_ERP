<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Form-->
    <record id="students_form_view_inherit" model="ir.ui.view">
        <field name="name">students.form.view.inherit</field>
        <field name="model">students.students</field>
        <field name="inherit_id" ref="students_school_erp.students_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='finance']" position="inside">
                <button name="%(action_print_finances)d" type="action" string="Print Finances"/>
                <field name="finance_ids" options="{'no_open':True, 'no_create':True, 'no_edit':True}" readonly="True">
                    <tree>
                        <field name="sequence" optional="hide" readonly="True"/>
                        <field name="student_id" optional="hide" readonly="True"/>
                        <field name="create_date" readonly="True"/>
                        <field name="reason" readonly="True"/>
                        <field name="state" widget="badge" readonly="True"
                               decoration-success="state == 'paid'"
                               decoration-danger="state == 'unpaid'"/>
                        <field name="amount" options="{'no_open':True, 'no_create':True}" readonly="True"/>
                    </tree>
                </field>
            </xpath>
        </field>
    </record>

</odoo>