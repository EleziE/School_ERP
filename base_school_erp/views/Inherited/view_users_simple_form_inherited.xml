<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>
        <record id="view_users_simple_form_inherited" model="ir.ui.view">
            <field name="name">view.users.simple.form.inherited</field>
            <field name="model">res.users</field>
            <field name="inherit_id" ref="base.view_users_simple_form"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@class='oe_title']" position="replace">
                    <group>
                        <field name="name"/>
                    </group>
                </xpath>
                <xpath expr="//field[@name='name']" position="after">
                    <field name="surname" string="Surname"/>
                </xpath>
                <xpath expr="//field[@name='surname']" position="after">
                    <field name="gender" string="Gender"/>
                </xpath>
                <xpath expr="//field[@name='gender']" position="after">
                    <field name="login" string="Login"/>
                </xpath>
                <xpath expr="//field[@name='login']" position="after">
                    <field name="member_type" string="Member Type"/>
                </xpath>
                <xpath expr="//field[@name='member_type']" position="after">
                    <field name="dob" string="Date of birth"/>
                </xpath>
                <xpath expr="//field[@name='dob']" position="after">
                    <field name="blood_type" string="Blood type"/>
                </xpath>
                <xpath expr="//field[@name='blood_type']" position="after">
                    <field name="email" string="Email" help="External email, not the one to login"/>
                </xpath>
                <xpath expr="//field[@name='email']" position="after">
                    <field name="partner_id" string="Partner ID"/>
                </xpath>
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="share" string="Share" invisible="1"/>
                </xpath>
                <xpath expr="//field[@name='phone']" position="attributes">
                    <attribute name="placeholder">+355 XX XXX XXXX</attribute>
                </xpath>
            </field>
        </record>
    </data>
</odoo>

