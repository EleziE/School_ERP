<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Form-->
    <record id="students_form_view_inherit" model="ir.ui.view">
        <field name="name">students.form.view.inherit</field>
        <field name="model">students.students</field>
        <field name="inherit_id" ref="students_school_erp.students_form_view"/>
        <field name="arch" type="xml">
            <!-- Filter subjects by student's faculty, year, semester -->
            <xpath expr="//field[@name='subject_id']" position="attributes">
                <attribute name="domain">[
                    ('faculty', '=', faculty),
                    ('year', '=', year),
                    ('semester', '=', semester)
                ]</attribute>
                <attribute name="context">{
                    'default_faculty': faculty,
                    'default_year': year,
                    'default_semester': semester
                }</attribute>
            </xpath>

        </field>
    </record>
</odoo>