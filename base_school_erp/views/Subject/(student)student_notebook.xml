<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Form-->
    <record id="students_form_view_inherit" model="ir.ui.view">
        <field name="name">students.form.view.inherit</field>
        <field name="model">students.students</field>
        <field name="inherit_id" ref="students_school_erp.students_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='subject']" position="inside">
                <field name="finance_ids" options="{'no_open':True, 'no_create':True}">
                    <tree>
                        <field name="state"/>
                        <field name="reason" />
                        <field name="amount" options="{'no_open':True, 'no_create':True}" readonly="True"/>
                    </tree>
                </field>
            </xpath>
        </field>
    </record>

</odoo>