<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Tree-->
    <record id="exam_tree_view" model="ir.ui.view">
        <field name="model">exams</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date_of_exam"/>
            </tree>
        </field>
    </record>


    <!--Action-->
    <record id="action_exam" model="ir.actions.act_window">
        <field name="name">Exam</field>
        <field name="res_model">exams</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--Only the groups that are added are allowed to see the icon of Finance module-->
    <record id="exam" model="ir.ui.menu">
        <field name="name">exam</field>
        <field name="groups_id" eval="[(6,0,[
                ref('base_school_erp.group_school_admin'),
                ref('base_school_erp.group_school_administration')]
                )]"/>

    </record>
</odoo>