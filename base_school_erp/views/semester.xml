<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Tree-->
    <record id="semester_tree_view" model="ir.ui.view">
        <field name="model">semester.semester</field>
        <field name="arch" type="xml">
            <tree>
                <field name="year_id"/>
                <field name="name"/>
                <field name="code"/>
                <field name="order"/>
            </tree>
        </field>
    </record>
    <!--Form-->
    <record id="semester_form_view" model="ir.ui.view">
        <field name="model">semester.semester</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="year_id"/>
                    <field name="name"/>
                    <field name="code"/>
                    <field name="order"/>
                </group>
            </form>
        </field>
    </record>
    <!--Action-->
    <record id="action_semester" model="ir.actions.act_window">
        <field name="name">Year</field>
        <field name="res_model">semester.semester</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--Only the groups that are added are allowed to see the icon of the  module-->
    <record id="semester" model="ir.ui.menu">
        <field name="name">semester</field>
        <field name="groups_id" eval="[(6,0,[
                ref('base_school_erp.group_school_admin'),
                ref('base_school_erp.group_school_administration')]
                )]"/>

    </record>
</odoo>