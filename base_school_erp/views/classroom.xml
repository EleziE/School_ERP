<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Tree-->
    <record id="class_tree_view" model="ir.ui.view">
        <field name="model">class.rooms</field>
        <field name="arch" type="xml">
            <tree editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>


    <!--Action-->
    <record id="action_class_room" model="ir.actions.act_window">
        <field name="name">Classrooms</field>
        <field name="res_model">class.rooms</field>
        <field name="view_mode">tree</field>
    </record>
    <!--menuitem-->
    <menuitem id="class_room"
              name="Classroom"
              parent='school_erp'
              action="action_class_room"/>
</odoo>