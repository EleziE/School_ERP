<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Tree-->
    <record id="subject_tree_view" model="ir.ui.view">
        <field name="model">subject.subject</field>
        <field name="arch" type="xml">
            <tree>
                <field name="sequence" optional="hide"/>
                <field name="name"/>
                <field name="faculty"/>
                <field name="semester"/>
                <field name="year"/>
                <field name="type"/>
                <field name="credits"/>
            </tree>
        </field>
    </record>
    <!--Form-->
    <record id="subject_form_view" model="ir.ui.view">
        <field name="model">subject.subject</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="sequence"/>
                    <field name="name"/>
                    <field name="year"/>
                    <field name="semester"/>
                    <field name="faculty"/>
                    <field name="type"/>
                    <field name="credits"/>
                </group>
            </form>
        </field>
    </record>
    <!--Search-->
    <record id="subject_view_search" model="ir.ui.view">
        <field name="name">subject.view.search</field>
        <field name="model">subject.subject</field>
        <field name="arch" type="xml">
            <search>
                <field name="sequence"/>
                <field name="name"/>
                <filter name="first-year" string="First Year" domain="[('year','=','1st')]"/>
                <filter name="second-year" string="Second Year" domain="[('year','=','2nd')]"/>
                <filter name="third-year" string="Third Year" domain="[('year','=','3rd')]"/>
                <separator/>
                <filter name="semester-1" string="First Semester" domain="[('semester','=','semester-1')]"/>
                <filter name="semester-2" string="Second Semester" domain="[('semester','=','semester-2')]"/>
                <separator/>
                <group expand="0" string="Group By">
                    <filter name="year" string="Year" context="{'group_by':'year'}"/>
                    <filter name="semester" string="Semester" context="{'group_by':'semester'}"/>
                </group>
            </search>
        </field>
    </record>

    <!--Action-->
    <record id="action_subject" model="ir.actions.act_window">
        <field name="name">Subject</field>
        <field name="res_model">subject.subject</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--menuitem-->
    <menuitem id="subject"
              name="Subject"
              parent='school_erp'
              action="action_subject"/>
</odoo>