<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Tree-->
    <record id="holidays_tree_view" model="ir.ui.view">
        <field name="model">holiday.holiday</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date"/>
            </tree>
        </field>
    </record>


    <!--Action-->
    <record id="action_holidays" model="ir.actions.act_window">
        <field name="name">Holiday</field>
        <field name="res_model">holiday.holiday</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--menuitem-->
    <menuitem id="holidays"
              name="Holidays"
              parent='school_erp'
              action="action_holidays"/>
</odoo>