<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!--Tree-->
    <record id="holidays_tree_view" model="ir.ui.view">
        <field name="model">holiday.holiday</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name"/>
                <field name="date"/>
            </tree>
        </field>
    </record>

    <!--Action-->
    <record id="action_holidays" model="ir.actions.act_window">
        <field name="name">Holiday</field>
        <field name="res_model">holiday.holiday</field>
        <field name="view_mode">tree,form</field>
    </record>
    <!--Only the groups that are added are allowed to see the icon of Finance module-->
    <record id="holidays" model="ir.ui.menu">
        <field name="groups_id" eval="[(6,0,[ref('base_school_erp.group_school_admin','base_school_erp.group_school_administration')])]"/>
    </record>
</odoo>